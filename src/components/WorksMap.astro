---
import { works } from '../data/works';
import '../styles/global.css';

const allTags = [...new Set(works.flatMap(w => w.tags ?? []))].sort();
const allYears = [...new Set(works.map(w => String(w.year)))].sort().reverse();

// マップとホイールを同期させるためのユニークIDを付与
const mappedWorks = works.map((w, i) => ({ ...w, _uid: i }));
---

<style>
  /* 全体レイアウトは維持 */
  :global(body.is-blurred) { filter: blur(20px) saturate(0.5); pointer-events: none; overflow: hidden; }
  :global(body) { background-color: #020205; margin: 0; color: white; min-height: 100vh; transition: filter 0.4s; }

  .main-layout {
    display: grid; grid-template-columns: 1fr 280px; gap: 20px;
    max-width: 1200px; margin: 20px auto; font-family: 'JetBrains Mono', monospace;
    opacity: 0; transition: opacity 1s;
  }
  :global(body:not(.is-blurred)) .main-layout { opacity: 1; }

  /* 🗺️ マップポイント */
  [data-work] { position: absolute; transition: transform 0.6s; opacity: 1; z-index: 10; }
  [data-work].is-filtered-out { opacity: 0; pointer-events: none; transform: scale(0); }
  
  /* 🌟 アクティブ（選択中）のグロー効果 */
  [data-work].is-active { z-index: 100 !important; }
  [data-work].is-active .point-core {
    background: #fff; box-shadow: 0 0 15px 2px cyan; transform: scale(1.5);
  }

  /* 🗨️ ツールチップ（情報表示） */
  .work-tooltip {
    position: absolute; width: 240px; opacity: 0; pointer-events: none;
    transform: translateY(10px); transition: all 0.2s ease; z-index: 200;
  }
  /* 表示優先度の制御用クラス */
  [data-work].show-info .work-tooltip {
    opacity: 1; pointer-events: auto; transform: translateY(0);
  }

  /* 🎚️ 右パネル構成 */
  .right-panel { display: flex; flex-direction: column; gap: 16px; }
  .hud-box {
    background: rgba(9, 9, 11, 0.9); border: 1px solid rgba(34, 211, 238, 0.1);
    backdrop-filter: blur(10px); padding: 15px;
  }

  /* 📜 ロータリー */
  .rotary-container { position: relative; height: 300px; overflow: hidden; }
  .rotary-viewport { height: 100%; overflow-y: auto; scrollbar-width: none; }
  .rotary-viewport::-webkit-scrollbar { display: none; }
  .rotary-item {
    height: 60px; display: flex; align-items: center; px: 15px;
    opacity: 0.2; transition: all 0.3s; cursor: pointer;
  }
  .rotary-item.is-visible { display: flex; }
  .rotary-item.is-hidden { display: none; }
  .rotary-item.is-focused { opacity: 1; color: cyan; }
</style>

<div id="start-overlay" class="fixed inset-0 z-[9999] flex items-center justify-center bg-black cursor-pointer">
  <span class="border border-cyan-500 text-cyan-500 px-6 py-3 tracking-[0.5em] animate-pulse">INITIATE SYSTEM</span>
</div>

<div class="main-layout px-4">
  <div class="relative aspect-square">
    <div id="map-target" class="w-full h-full bg-zinc-950/40 border border-zinc-800 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(cyan 1px, transparent 1px); background-size: 30px 30px;"></div>
      
      <div class="absolute inset-16 sm:inset-24">
        {mappedWorks.map((work) => {
          const left = ((work.x + 100) / 200) * 100;
          const bottom = ((work.y + 100) / 200) * 100;
          const ytId = work.url?.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=)([^#\&\?]*)/)?.[1];
          return (
            <div 
              data-work 
              data-uid={work._uid}
              data-tags={work.tags?.join(",") ?? ""} 
              data-year={work.year}
              class="group" 
              style={`left: ${left}%; bottom: ${bottom}%;`}
            >
              <div class="relative w-6 h-6 flex items-center justify-center cursor-pointer" 
                   onmouseenter={`handlePointHover(${work._uid}, true)`}
                   onmouseleave={`handlePointHover(${work._uid}, false)`}
                   onclick={`syncWheelToMap(${work._uid})`}>
                <div class="point-core w-1.5 h-1.5 bg-zinc-500 transition-all duration-300"></div>
              </div>

              <div class={`work-tooltip ${bottom > 70 ? 'top-8' : 'bottom-8'} ${left > 70 ? 'right-0' : 'left-0'}`}>
                <div class="bg-zinc-900 border border-cyan-500/50 p-3 shadow-2xl">
                  {ytId && <img src={`https://img.youtube.com/vi/${ytId}/mqdefault.jpg`} class="w-full aspect-video object-cover mb-2" />}
                  <p class="text-[9px] text-cyan-400 mb-1">{work.artist} / {work.year}</p>
                  <p class="text-xs font-bold leading-tight">{work.title}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
    <div class="flex flex-wrap gap-2 mt-4 text-[10px]">
      <button onclick="setFilter('tag', null)" class="px-2 py-1 border border-zinc-700">ALL TAGS</button>
      {allTags.map(tag => <button id={`btn-tag-${tag}`} onclick={`setFilter('tag', '${tag}')`} class="px-2 py-1 border border-zinc-800">{tag}</button>)}
    </div>
  </div>

  <div class="right-panel">
    <aside class="hud-box space-y-4">
      <div><label class="text-[8px] text-cyan-500">MASTER GAIN</label><input type="range" class="w-full" id="vol-fader"></div>
      <div><label class="text-[8px] text-cyan-500">TEMPORAL VELOCITY</label><input type="range" class="w-full" id="speed-fader"></div>
      <div><label class="text-[8px] text-cyan-500">DISTORTION (ENTROPY)</label><input type="range" class="w-full" id="dist-fader"></div>
      <div><label class="text-[8px] text-cyan-500">DELAY (ECHOES)</label><input type="range" class="w-full" id="delay-fader"></div>
      <div><label class="text-[8px] text-cyan-500">REVERB (SPACE)</label><input type="range" class="w-full" id="reverb-fader"></div>
      <div class="pt-2 border-t border-zinc-800 text-[8px] text-cyan-900 uppercase" id="doppler-status">SHIFT: STABLE</div>
      <button id="play-pause-btn" class="w-full border border-cyan-900 text-cyan-500 text-[8px] py-1">PAUSE TRANSMISSION</button>
    </aside>

    <aside class="hud-box !p-0 overflow-hidden flex flex-col">
      <div class="p-3 border-b border-zinc-800 text-[8px] text-zinc-500 uppercase tracking-widest">Archive Works</div>
      <div class="rotary-container">
        <div id="rotary-viewport" class="rotary-viewport">
          <div style="height: 120px;"></div> <div id="rotary-list">
            {mappedWorks.map((work) => (
              <div class="rotary-item" data-uid={work._uid} onclick={`syncWheelToMap(${work._uid})`}>
                <div class="w-1 h-1 bg-current rounded-full mr-3"></div>
                <div class="truncate">
                  <div class="text-[7px] opacity-50 uppercase">{work.artist}</div>
                  <div class="text-[10px] leading-none">{work.title}</div>
                </div>
              </div>
            ))}
          </div>
          <div style="height: 120px;"></div> </div>
      </div>
    </aside>
  </div>
</div>

<script>
  let currentTag = null;
  let currentYear = null;
  let isStarted = false;
  let isScrolling = false;
  let wheelActiveUid = null;
  let hoverActiveUid = null;

  // --------------------------------------------------
  // 🎯 同期 & 表示ロジック
  // --------------------------------------------------
  function updateDisplayState() {
    const allPoints = document.querySelectorAll('[data-work]');
    
    // 優先順位: ホバーがあればホバーを、なければホイールを表示
    const activeUid = hoverActiveUid !== null ? hoverActiveUid : wheelActiveUid;

    allPoints.forEach(el => {
      const uid = parseInt(el.dataset.uid);
      
      // フィルタ判定
      const tags = el.dataset.tags.split(',');
      const year = el.dataset.year;
      const isMatch = (!currentTag || tags.includes(currentTag)) && (!currentYear || year === currentYear);
      
      el.classList.toggle('is-filtered-out', !isMatch);
      el.classList.toggle('is-active', uid === wheelActiveUid);
      
      // 情報パネル表示（アクティブなUIDかつフィルタに合致している場合のみ）
      el.classList.toggle('show-info', isMatch && uid === activeUid);
    });

    // ロータリー側のハイライト
    document.querySelectorAll('.rotary-item').forEach(item => {
      const uid = parseInt(item.dataset.uid);
      item.classList.toggle('is-focused', uid === wheelActiveUid);
    });
  }

  // ホバー処理
  window.handlePointHover = (uid, isEnter) => {
    if (isEnter) {
      hoverActiveUid = uid;
    } else {
      hoverActiveUid = null;
    }
    updateDisplayState();
  };

  // --------------------------------------------------
  // 📜 ロータリー制御 (数学的同期)
  // --------------------------------------------------
  const viewport = document.getElementById('rotary-viewport');
  const itemHeight = 60;

  viewport.addEventListener('scroll', () => {
    hoverActiveUid = null; // スクロール中はホバー解除を優先
    const scrollPos = viewport.scrollTop;
    
    // フィルタで表示されている要素だけを取得
    const visibleItems = Array.from(document.querySelectorAll('.rotary-item:not(.is-hidden)'));
    if (visibleItems.length === 0) return;

    // 中央に最も近い要素のインデックスを計算
    const index = Math.round(scrollPos / itemHeight);
    const safeIndex = Math.max(0, Math.min(index, visibleItems.length - 1));
    
    const newUid = parseInt(visibleItems[safeIndex].dataset.uid);
    if (wheelActiveUid !== newUid) {
      wheelActiveUid = newUid;
      updateDisplayState();
    }
  });

  window.syncWheelToMap = (uid) => {
    const visibleItems = Array.from(document.querySelectorAll('.rotary-item:not(.is-hidden)'));
    const targetIdx = visibleItems.findIndex(item => parseInt(item.dataset.uid) === uid);
    if (targetIdx !== -1) {
      viewport.scrollTo({ top: targetIdx * itemHeight, behavior: 'smooth' });
    }
  };

  // --------------------------------------------------
  // ⚡ フィルタリング
  // --------------------------------------------------
  window.setFilter = (type, value) => {
    if (type === 'tag') currentTag = value;
    
    // ロータリーリストの表示/非表示を切り替え
    document.querySelectorAll('.rotary-item').forEach(item => {
      const el = document.querySelector(`[data-work][data-uid="${item.dataset.uid}"]`);
      const tags = el.dataset.tags.split(',');
      const isMatch = !currentTag || tags.includes(currentTag);
      item.classList.toggle('is-hidden', !isMatch);
    });

    updateDisplayState();
    // フィルタ後に一番上の要素にスクロール
    viewport.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // 開始処理
  function startExperience() {
    isStarted = true;
    document.getElementById('start-overlay').style.display = 'none';
    document.body.classList.remove('is-blurred');
    // 初期選択
    const firstItem = document.querySelector('.rotary-item:not(.is-hidden)');
    if (firstItem) wheelActiveUid = parseInt(firstItem.dataset.uid);
    updateDisplayState();
  }

  document.getElementById('start-overlay').addEventListener('click', startExperience);
</script>

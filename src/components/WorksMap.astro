---
import { works } from '../data/works';
import '../styles/global.css';

// 🔥 フィルタリング用データの抽出
const allTags = [...new Set(works.flatMap(w => w.tags ?? []))].sort();
const allYears = [...new Set(works.map(w => String(w.year)))].sort().reverse();

// マップとホイールを同期させるためのユニークIDを付与
const mappedWorks = works.map((w, i) => ({ ...w, _uid: i }));
---

<style>
  /* --------------------------------------------------
   * 🌫️ 【仕様固定】初期状態
   * -------------------------------------------------- */
  :global(body.is-blurred) { filter: blur(20px) saturate(0.5); pointer-events: none; overflow: hidden; }
  :global(body) { background-color: #020205; margin: 0; color: white; min-height: 100vh; transition: filter 0.4s; }

  #start-overlay {
    position: fixed; inset: 0; z-index: 9999; display: flex; flex-direction: column; gap: 16px;
    align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.95); cursor: pointer;
  }
  #start-overlay.hidden { opacity: 0; visibility: hidden; }

  /* 🗺️ マップポイント（浮遊感デザイン維持） */
  [data-work] { position: absolute; transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s; z-index: 10; }
  [data-work].is-filtered-out { opacity: 0; pointer-events: none; transform: scale(0); }
  
  .point-core { width: 6px; height: 6px; background: #3f3f46; border-radius: 1px; transition: all 0.3s; }
  [data-work].is-active { z-index: 100 !important; }
  [data-work].is-active .point-core { background: #fff; box-shadow: 0 0 15px 2px cyan; transform: scale(1.5); }

  /* 🗨️ 情報表示スタイル（デザイン維持） */
  .work-tooltip {
    position: absolute; width: 200px; opacity: 0; pointer-events: none;
    transform: translateY(10px); transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1); z-index: 200;
  }
  /* 表示優先度ロジック用クラス */
  [data-work].show-info .work-tooltip { opacity: 1; pointer-events: auto; transform: translateY(0); }

  /* 📜 ロータリー（デザイン維持） */
  .rotary-container { position: relative; height: 320px; overflow: hidden; }
  .rotary-viewport { height: 100%; overflow-y: auto; scrollbar-width: none; scroll-behavior: smooth; }
  .rotary-viewport::-webkit-scrollbar { display: none; }
  .rotary-item {
    height: 80px; display: flex; align-items: center; padding: 0 20px;
    opacity: 0.15; transition: all 0.4s; cursor: pointer;
  }
  .rotary-item.is-hidden { display: none; }
  .rotary-item.is-focused { opacity: 1; color: cyan; }

  /* レイアウト */
  .main-layout { display: grid; grid-template-columns: 1fr 300px; gap: 30px; max-width: 1300px; margin: 40px auto; opacity: 0; transition: opacity 1s; }
  :global(body:not(.is-blurred)) .main-layout { opacity: 1; }
</style>

<div id="start-overlay">
  <span class="border border-zinc-700 text-zinc-500 px-6 py-2 text-[10px] tracking-[0.5em] animate-pulse uppercase">Initiate System</span>
</div>

<div class="main-layout px-6">
  <div class="flex flex-col gap-6">
    <div class="flex flex-col gap-4 bg-zinc-900/30 p-4 border border-zinc-800/50">
      <div class="flex flex-wrap gap-2">
        <button id="btn-tag-all" onclick="setTag(null)" class="text-[9px] px-2 py-1 border border-zinc-800 uppercase">All Types</button>
        {allTags.map(tag => <button id={`btn-tag-${tag}`} onclick={`setTag('${tag}')`} class="text-[9px] px-2 py-1 border border-zinc-800 uppercase">{tag}</button>)}
      </div>
      <div class="flex flex-wrap gap-2">
        <button id="btn-year-all" onclick="setYear(null)" class="text-[9px] px-2 py-1 border border-zinc-800 uppercase">All Time</button>
        {allYears.map(year => <button id={`btn-year-${year}`} onclick={`setYear('${year}')`} class="text-[9px] px-2 py-1 border border-zinc-800 uppercase">{year}</button>)}
      </div>
    </div>

    <div id="map-target" class="relative aspect-video bg-zinc-950 border border-zinc-800 overflow-hidden">
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(cyan 1px, transparent 1px); background-size: 40px 40px;"></div>
      
      <div class="absolute inset-20">
        {mappedWorks.map((work) => {
          const left = ((work.x + 100) / 200) * 100;
          const bottom = ((work.y + 100) / 200) * 100;
          const ytId = work.url?.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=)([^#\&\?]*)/)?.[1];
          return (
            <div 
              data-work 
              data-uid={work._uid}
              data-tags={work.tags?.join(",") ?? ""} 
              data-year={work.year}
              style={`left: ${left}%; bottom: ${bottom}%;`}
              onmouseenter={`handlePointHover(${work._uid}, true)`}
              onmouseleave={`handlePointHover(${work._uid}, false)`}
              onclick={`syncWheelToMap(${work._uid})`}
            >
              <div class="group relative w-8 h-8 flex items-center justify-center cursor-pointer">
                <div class="point-core"></div>
              </div>

              <div class={`work-tooltip ${bottom > 70 ? 'top-10' : 'bottom-10'} ${left > 70 ? 'right-0' : 'left-0'}`}>
                <div class="bg-zinc-900 border border-cyan-900/50 p-2 shadow-2xl backdrop-blur-md">
                  {ytId && <img src={`https://img.youtube.com/vi/${ytId}/mqdefault.jpg`} class="w-full aspect-video object-cover mb-2" />}
                  <p class="text-[8px] text-cyan-500 mb-1 tracking-tighter">{work.artist} [{work.year}]</p>
                  <p class="text-[10px] font-bold leading-tight line-clamp-2">{work.title}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-6">
    <aside class="bg-zinc-900/50 border border-zinc-800 p-4 space-y-4">
      <div class="text-[8px] text-zinc-500 border-b border-zinc-800 pb-2 uppercase tracking-[0.2em]">Environmental Control</div>
      <div><label class="text-[7px] text-cyan-900">GAIN</label><input type="range" class="w-full h-1 bg-zinc-800 accent-cyan-600 appearance-none" id="vol-fader"></div>
      <div id="v-bar-container" class="h-1 w-full bg-zinc-900 overflow-hidden"><div id="v-bar" class="h-full bg-cyan-500/30 w-0"></div></div>
      <button id="play-pause-btn" class="w-full border border-cyan-900/30 text-cyan-700 text-[8px] py-1 uppercase tracking-widest hover:bg-cyan-500/10 transition-colors">System Active</button>
    </aside>

    <aside class="bg-zinc-900/50 border border-zinc-800 overflow-hidden">
      <div class="p-3 border-b border-zinc-800 text-[8px] text-zinc-500 uppercase tracking-widest">Navigation Wheel</div>
      <div class="rotary-container">
        <div id="rotary-viewport" class="rotary-viewport">
          <div style="height: 120px;"></div> <div id="rotary-list">
            {mappedWorks.map((work) => (
              <div class="rotary-item" data-uid={work._uid} onclick={`syncWheelToMap(${work._uid})`}>
                <div class="w-1 h-1 bg-current mr-4"></div>
                <div class="truncate">
                  <div class="text-[7px] opacity-40 uppercase tracking-tighter">{work.artist}</div>
                  <div class="text-[11px] leading-tight font-medium">{work.title}</div>
                </div>
              </div>
            ))}
          </div>
          <div style="height: 120px;"></div> </div>
      </div>
    </aside>
  </div>
</div>

<script>
  let currentTag = null;
  let currentYear = null;
  let isStarted = false;
  let wheelActiveUid = null;
  let hoverActiveUid = null;

  const viewport = document.getElementById('rotary-viewport');
  const itemHeight = 80;

  // --------------------------------------------------
  // 🎯 同期 & 表示ロジック（優先順位制御）
  // --------------------------------------------------
  function updateDisplayState() {
    const allPoints = document.querySelectorAll('[data-work]');
    
    // 優先順位: ホバー中の点があればそれを、なければホイールの選択値を表示
    const activeUid = hoverActiveUid !== null ? hoverActiveUid : wheelActiveUid;

    allPoints.forEach(el => {
      const uid = parseInt(el.dataset.uid);
      const tags = (el.dataset.tags || "").split(",");
      const year = el.dataset.year;

      // フィルタ判定
      const tagMatch = !currentTag || tags.includes(currentTag);
      const yearMatch = !currentYear || year === currentYear;
      const isMatch = tagMatch && yearMatch;
      
      el.classList.toggle('is-filtered-out', !isMatch);
      el.classList.toggle('is-active', uid === wheelActiveUid);
      
      // 情報表示パネルの制御
      el.classList.toggle('show-info', isMatch && uid === activeUid);
    });

    // ロータリー側のハイライト
    document.querySelectorAll('.rotary-item').forEach(item => {
      const uid = parseInt(item.dataset.uid);
      item.classList.toggle('is-focused', uid === wheelActiveUid);
    });
  }

  // --------------------------------------------------
  // 📜 ロータリー制御 (数学的インデックス同期)
  // --------------------------------------------------
  viewport.addEventListener('scroll', () => {
    // スクロール中はホバー情報をリセットしてホイール表示を優先
    hoverActiveUid = null; 
    
    const visibleItems = Array.from(document.querySelectorAll('.rotary-item:not(.is-hidden)'));
    if (visibleItems.length === 0) return;

    // 中央に最も近い要素を計算
    const index = Math.round(viewport.scrollTop / itemHeight);
    const safeIndex = Math.max(0, Math.min(index, visibleItems.length - 1));
    
    const newUid = parseInt(visibleItems[safeIndex].dataset.uid);
    if (wheelActiveUid !== newUid) {
      wheelActiveUid = newUid;
      updateDisplayState();
    }
  });

  window.handlePointHover = (uid, isEnter) => {
    hoverActiveUid = isEnter ? uid : null;
    updateDisplayState();
  };

  window.syncWheelToMap = (uid) => {
    const visibleItems = Array.from(document.querySelectorAll('.rotary-item:not(.is-hidden)'));
    const targetIdx = visibleItems.findIndex(item => parseInt(item.dataset.uid) === uid);
    if (targetIdx !== -1) {
      viewport.scrollTo({ top: targetIdx * itemHeight, behavior: 'smooth' });
    }
  };

  // --------------------------------------------------
  // ⚡ フィルタリング連動
  // --------------------------------------------------
  function applyFilters() {
    // ロータリー項目の表示/非表示をまず更新
    document.querySelectorAll('.rotary-item').forEach(item => {
      const el = document.querySelector(`[data-work][data-uid="${item.dataset.uid}"]`);
      const tags = el.dataset.tags.split(',');
      const year = el.dataset.year;
      
      const isMatch = (!currentTag || tags.includes(currentTag)) && (!currentYear || year === currentYear);
      item.classList.toggle('is-hidden', !isMatch);
    });

    // ボタンの外観更新
    document.querySelectorAll("button[id^='btn-']").forEach(btn => btn.classList.remove('border-cyan-500', 'text-cyan-400'));
    const activeTagBtn = currentTag ? document.getElementById(`btn-tag-${currentTag}`) : document.getElementById('btn-tag-all');
    activeTagBtn?.classList.add('border-cyan-500', 'text-cyan-400');
    const activeYearBtn = currentYear ? document.getElementById(`btn-year-${currentYear}`) : document.getElementById('btn-year-all');
    activeYearBtn?.classList.add('border-cyan-500', 'text-cyan-400');

    updateDisplayState();
    // フィルタ後は一番上にスクロール
    viewport.scrollTo({ top: 0, behavior: 'smooth' });
  }

  window.setTag = (tag) => { if(!isStarted) startExperience(); currentTag = tag; applyFilters(); };
  window.setYear = (year) => { if(!isStarted) startExperience(); currentYear = year; applyFilters(); };

  // 開始処理
  function startExperience() {
    isStarted = true;
    document.getElementById('start-overlay').classList.add('hidden');
    document.body.classList.remove('is-blurred');
    const firstItem = document.querySelector('.rotary-item:not(.is-hidden)');
    if (firstItem) wheelActiveUid = parseInt(firstItem.dataset.uid);
    updateDisplayState();
  }

  document.getElementById('start-overlay').addEventListener('click', startExperience);
</script>

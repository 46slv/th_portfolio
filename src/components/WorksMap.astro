---
import { works } from '../data/works';
import '../styles/global.css';

// 📊 フィルタリング用データの抽出
const allTags = [...new Set(works.flatMap(w => w.tags ?? []))].sort();
const allYears = [...new Set(works.map(w => String(w.year)))].sort().reverse();
---

<style>
  /* --------------------------------------------------
   * 🌫️ 【仕様固定】画面全体の初期状態（ブラー）
   * -------------------------------------------------- */
  :global(body.is-blurred) {
    filter: blur(20px) saturate(0.5);
    pointer-events: none;
    overflow: hidden;
  }

  :global(body) {
    background-color: #020205; 
    margin: 0;
    color: white;
    min-height: 100vh;
    transition: filter 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }

  /* 🎬 始動用オーバーレイ */
  #start-overlay {
    position: fixed; inset: 0; z-index: 9999;
    display: flex; flex-direction: column; gap: 16px;
    align-items: center; justify-content: center;
    background: rgba(0, 0, 0, 0.95);
    cursor: pointer; pointer-events: auto !important;
    transition: opacity 0.8s ease, visibility 0.8s;
  }
  #start-overlay.hidden { opacity: 0; visibility: hidden; }

  /* 📧 Contact Bar */
  .contact-bar {
    display: flex;
    justify-content: flex-end;
    padding: 10px 20px;
    font-size: 10px;
    letter-spacing: 0.2em;
    border-bottom: 1px solid rgba(34, 211, 238, 0.1);
    position: relative;
    z-index: 10;
  }
  .contact-link {
    color: #71717a;
    text-decoration: none;
    cursor: pointer;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .contact-link:hover { color: #22d3ee; }

  /* 🔵 メインレイアウト */
  .main-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 20px;
    max-width: 1400px;
    margin: 20px auto;
    padding: 0 20px;
    font-family: 'JetBrains Mono', monospace;
    opacity: 0;
    transition: opacity 1s ease 0.5s;
  }
  :global(body:not(.is-blurred)) .main-layout { opacity: 1; }

  /* 🗺️ マップコンテナ */
  .map-container {
    perspective: 1200px;
    transform-style: preserve-3d;
    position: relative;
    isolation: isolate;
  }
  
  [data-work] {
    position: absolute;
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translate(-50%, 50%);
    will-change: transform, opacity;
  }
  
  [data-work].is-active {
    opacity: 1;
    z-index: 200 !important;
    transform: translate(-50%, 50%) translateZ(100px) scale(1.4);
    filter: drop-shadow(0 0 15px rgba(34, 211, 238, 0.8));
  }
  
  [data-work].is-inactive {
    opacity: 0.2;
    z-index: 1;
    transform: translate(-50%, 50%) translateZ(-50px) scale(0.9);
  }

  /* 🎚️ オーディオHUD */
  .audio-hud {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px;
    background: rgba(9, 9, 11, 0.8);
    border: 1px solid rgba(34, 211, 238, 0.1);
    height: fit-content;
    position: relative;
    z-index: 20;
    backdrop-filter: blur(10px);
  }
  .control-group { display: flex; flex-direction: column; gap: 6px; }
  .control-label {
    font-size: 8px;
    color: #22d3ee;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  input[type="range"] {
    appearance: none;
    background: #18181b;
    height: 2px;
    outline: none;
    width: 100%;
  }
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 8px;
    height: 8px;
    background: #22d3ee;
    border-radius: 50%;
    cursor: pointer;
  }

  /* -------------------------------
     Rotary Wheel
  -------------------------------- */
  .rotary-container {
    position: relative;
    width: 240px;
    height: 240px;
    margin-top: 20px;
    border: 1px solid rgba(34, 211, 238, 0.1);
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
  }

  .rotary-wheel {
    position: absolute;
    inset: 0;
    transform-origin: center;
    transition: transform 0.6s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .rotary-item {
    position: absolute;
    left: 50%;
    top: 50%;
    /* transform-originを調整して円の半径を決定 */
    transform-origin: center 100px;
    font-size: 7px;
    color: #71717a;
    white-space: nowrap;
    pointer-events: none;
    text-align: center;
    width: 120px;
    margin-left: -60px;
    margin-top: -100px; /* 半径分上げる */
  }

  .rotary-item.is-active {
    color: #22d3ee;
    font-weight: bold;
    text-shadow: 0 0 8px rgba(34, 211, 238, 0.5);
  }

  .rotary-center {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 5;
  }

  .rotary-active {
    font-size: 8px;
    color: #22d3ee;
    border: 1px solid rgba(34, 211, 238, 0.3);
    padding: 6px 10px;
    background: rgba(0, 0, 0, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    max-width: 160px;
    text-align: center;
    white-space: normal;
  }
</style>

<div id="start-overlay">
  <span class="text-cyan-400 text-[10px] tracking-[0.4em] animate-pulse uppercase border border-cyan-400/50 px-4 py-2 bg-black/60">Initialize System</span>
  <p class="text-zinc-600 text-[8px] uppercase tracking-widest mt-2">Click Anywhere to Begin</p>
</div>

<div class="contact-bar">
  <div class="contact-link" onclick="navigator.clipboard.writeText('info@corecreative.jp')">
    <span class="text-zinc-500">CONTACT:</span>
    <span id="contact-text">info@corecreative.jp</span>
  </div>
</div>

<div class="max-w-4xl mx-auto pt-6 px-4 space-y-4">
  <div class="flex flex-wrap gap-2 text-[10px]">
    <button id="btn-all" onclick="setTag(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 transition-all uppercase">All Tags</button>
    {allTags.map(tag => (
      <button id={`btn-${tag}`} onclick={`setTag("${tag}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 transition-all uppercase">{tag}</button>
    ))}
  </div>
  <div class="flex flex-wrap gap-2 text-[10px]">
    <button id="btn-year-all" onclick="setYear(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 transition-all uppercase">All Years</button>
    {allYears.map(year => (
      <button id={`btn-year-${year}`} onclick={`setYear("${year}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 transition-all uppercase">{year}</button>
    ))}
  </div>
</div>

<div class="main-layout">
  <div class="relative aspect-square px-4">
    <div id="map-target" class="map-container w-full h-full bg-zinc-950/40 border border-zinc-800 overflow-hidden font-mono text-[10px]">
      <div class="absolute inset-16 sm:inset-24">
        {works.map((work) => {
          const left = ((work.x + 100) / 200) * 100;
          const bottom = ((work.y + 100) / 200) * 100;
          return (
            <div 
              data-work 
              data-tags={work.tags?.join(",") ?? ""} 
              data-year={work.year}
              class="group absolute cursor-crosshair" 
              style={`left: ${left}%; bottom: ${bottom}%; z-index: ${Math.round(bottom)};`}
            >
              <div class="relative w-4 h-4 flex items-center justify-center">
                <div class="absolute w-full h-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
                <div class="absolute h-full w-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
                <div class="w-1 h-1 bg-white"></div>
              </div>

              <div class={`absolute mb-2 w-[220px] z-[300] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-300 ${bottom > 70 ? 'top-6' : 'bottom-full'} ${left > 70 ? 'right-4' : 'left-4'}`}>
                <div class="bg-black/95 border-l-2 border-cyan-500 p-3 shadow-2xl backdrop-blur-xl">
                  <p class="text-white font-bold leading-tight mb-2">{work.title}</p>
                  <div class="flex gap-2 text-zinc-500 text-[8px] mb-3">
                    <span>{work.year}</span>
                    <span>/</span>
                    <span>{work.tags?.join(", ")}</span>
                  </div>
                  <a href={work.url} target="_blank" class="block text-[9px] text-zinc-400 border border-zinc-800 px-2 py-1.5 uppercase hover:bg-cyan-900/30 hover:text-cyan-400 transition-colors">
                    Access Data →
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <aside class="audio-hud">
    <div class="control-group">
      <label class="control-label">Master Gain</label>
      <input type="range" id="vol-fader" min="0" max="1" step="0.01" value="0.5">
    </div>
    
    <div class="rotary-container">
      <div id="rotary-wheel" class="rotary-wheel">
        {works.map((work, i) => (
          <div 
            class="rotary-item"
            data-index={i}
          >
            <span class="rotary-label">{work.title}</span>
          </div>
        ))}
      </div>

      <div class="rotary-center">
        <div id="rotary-active" class="rotary-active">
          SELECT
        </div>
      </div>
    </div>

    <button id="play-pause-btn" class="mt-4 w-full border border-cyan-900/50 text-cyan-500 text-[8px] py-1 uppercase tracking-widest hover:bg-cyan-500/10">Pause Transmission</button>
  </aside>
</div>

<script>
  let currentTag = null;
  let currentYear = null;
  let isStarted = false;

  function applyFilters() {
    const allWorks = document.querySelectorAll("[data-work]");
    
    // ボタン状態更新
    document.querySelectorAll("button[id^='btn-']").forEach(btn => btn.classList.remove('border-cyan-500', 'text-cyan-400'));
    const activeTagBtn = currentTag ? document.getElementById(`btn-${currentTag}`) : document.getElementById('btn-all');
    activeTagBtn?.classList.add('border-cyan-500', 'text-cyan-400');
    const activeYearBtn = currentYear ? document.getElementById(`btn-year-${currentYear}`) : document.getElementById('btn-year-all');
    activeYearBtn?.classList.add('border-cyan-500', 'text-cyan-400');

    allWorks.forEach((el: any) => {
      const tags = (el.dataset.tags || "").split(",").map((t: string) => t.trim()).filter(Boolean);
      const year = el.dataset.year;
      
      const tagMatch = !currentTag || tags.includes(currentTag);
      const yearMatch = !currentYear || year === currentYear;

      if (tagMatch && yearMatch) {
        el.classList.remove('is-inactive');
        if (currentTag || currentYear) el.classList.add('is-active');
        else el.classList.remove('is-active');
      } else {
        el.classList.add('is-inactive');
        el.classList.remove('is-active');
      }
    });
  }

  (window as any).setTag = (tag: string) => { if (!isStarted) startExperience(); currentTag = tag; applyFilters(); };
  (window as any).setYear = (year: string) => { if (!isStarted) startExperience(); currentYear = year; applyFilters(); };

  async function startExperience() {
    if (isStarted) return;
    isStarted = true;
    document.getElementById('start-overlay').classList.add('hidden');
    document.body.classList.remove('is-blurred');
  }

  /* -------------------------------
     Rotary Wheel Logic
  -------------------------------- */
  let rotaryIndex = 0;
  let rotaryItems = [];
  let rotaryTotal = 0;

  function initRotary() {
    const wheelElement = document.getElementById('rotary-wheel');
    if (!wheelElement) return;

    const items = wheelElement.querySelectorAll('.rotary-item');
    rotaryItems = Array.from(items);
    rotaryTotal = rotaryItems.length;

    if (rotaryTotal === 0) return;

    const step = 360 / rotaryTotal;

    rotaryItems.forEach((el: any, i: number) => {
      const angle = step * i;
      // 円形に並べるための計算: 軸を回転させてから要素を戻す
      el.style.transform = `rotate(${angle}deg) translateY(0px) rotate(${-angle}deg)`;
    });

    updateRotary();
  }

  function updateRotary() {
    const wheel = document.getElementById('rotary-wheel');
    const activeDisplay = document.getElementById('rotary-active');
    if (!wheel || !activeDisplay) return;

    const step = 360 / rotaryTotal;
    const angle = -rotaryIndex * step;

    wheel.style.transform = `rotate(${angle}deg)`;

    rotaryItems.forEach(el => el.classList.remove('is-active'));

    const active = rotaryItems[rotaryIndex] as HTMLElement;
    if (active) {
      active.classList.add('is-active');
      activeDisplay.innerText = active.innerText;
    }
  }

  function rotateWheel(dir: number) {
    if (rotaryTotal === 0) return;
    rotaryIndex += dir;

    if (rotaryIndex < 0) rotaryIndex = rotaryTotal - 1;
    if (rotaryIndex >= rotaryTotal) rotaryIndex = 0;

    updateRotary();
  }

  /* init */
  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('start-overlay').addEventListener('click', startExperience);
    
    // ホイール初期化を少し遅らせる
    setTimeout(initRotary, 150);

    /* mouse wheel control */
    document.addEventListener('wheel', (e) => {
      // ブラー状態（開始前）は無視
      if (!isStarted) return;
      if (Math.abs(e.deltaY) < 10) return;

      if (e.deltaY > 0) rotateWheel(1);
      else rotateWheel(-1);
    }, { passive: true });
  });
</script>

---
import { works } from '../data/works';
import '../styles/global.css';

const allTags = [...new Set(works.flatMap(w => w.tags ?? []))];
---

<style>
  .main-layout {
    display: grid;
    grid-template-columns: 1fr 240px; /* 左：マップ / 右：オーディオ制御 */
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    font-family: 'JetBrains Mono', monospace;
  }

  .map-container {
    perspective: 1200px;
    transform-style: preserve-3d;
    position: relative;
    isolation: isolate;
    transition: filter 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* 🌫️ 初期状態の靄（ブラー） */
  .is-blurred {
    filter: blur(20px) saturate(0.5);
    pointer-events: none;
  }

  /* 始動オーバーレイ */
  #start-overlay {
    position: absolute;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    cursor: pointer;
    transition: opacity 0.8s ease;
  }
  #start-overlay.hidden { opacity: 0; pointer-events: none; }

  @keyframes float {
    0%, 100% { transform: translate(-50%, 50%) rotate(0deg); }
    33% { transform: translate(calc(-50% + 4px), calc(50% - 6px)) rotate(1deg); }
    66% { transform: translate(calc(-50% - 3px), calc(50% - 2px)) rotate(-1deg); }
  }

  [data-work] {
    position: absolute;
    transition: opacity 0.6s, transform 0.6s, filter 0.6s;
    will-change: transform, opacity;
    transform: translate(-50%, 50%) translateZ(0px);
  }

  [data-work].is-active { opacity: 1 !important; z-index: 100; transform: translate(-50%, 50%) translateZ(100px) scale(1.2); }
  [data-work].is-inactive { opacity: 0.1 !important; transform: translate(-50%, 50%) translateZ(-200px); }

  .animate-float { animation: float 6s ease-in-out infinite; }

  /* 🎚️ 右側フェーダー群 */
  .audio-hud {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 20px;
    background: rgba(9, 9, 11, 0.5);
    border: 1px solid rgba(34, 211, 238, 0.1);
    height: fit-content;
  }

  .control-group { display: flex; flex-direction: column; gap: 8px; }
  .control-label { font-size: 9px; color: #22d3ee; text-transform: uppercase; letter-spacing: 0.1em; }
  
  input[type="range"] {
    appearance: none;
    background: #27272a;
    height: 2px;
    width: 100%;
    outline: none;
  }
  input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 10px;
    height: 10px;
    background: #22d3ee;
    cursor: pointer;
    border-radius: 50%;
    box-shadow: 0 0 8px #22d3ee;
  }

  /* ツールチップ（既存維持） */
  .custom-scrollbar::-webkit-scrollbar { width: 2px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #22d3ee; }
</style>

<div class="max-w-4xl mx-auto mb-4 flex flex-wrap gap-2 text-xs">
  <button id="btn-all" onclick="setTag(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 transition-all">ALL</button>
  {allTags.map(tag => (
    <button id={`btn-${tag}`} onclick={`setTag("${tag}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 transition-all">{tag}</button>
  ))}
</div>

<div class="main-layout">
  <div class="relative aspect-square">
    <div id="start-overlay" onclick="startExperience()">
      <span class="text-cyan-400 text-[10px] tracking-[0.4em] animate-pulse uppercase border border-cyan-400/50 px-4 py-2 bg-black/60 backdrop-blur-sm">Initialize System</span>
    </div>

    <div id="map-target" class="map-container is-blurred w-full h-full bg-zinc-950 border border-zinc-800 overflow-hidden font-mono text-[10px]">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #27272a 1px, transparent 1px); background-size: 20px 20px;"></div>
      
      <div class="absolute inset-16 sm:inset-24">
        {works.map((work, index) => {
          const left = ((work.x + 100) / 200) * 100;
          const bottom = ((work.y + 100) / 200) * 100;
          const ytId = work.url?.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=)([^#\&\?]*)/)?.[1];

          return (
            <div data-work data-tags={work.tags?.join(",") ?? ""} class="group absolute cursor-crosshair animate-float" style={`left: ${left}%; bottom: ${bottom}%; animation-delay: ${index * 0.2}s;`}>
              <a href={work.url} target="_blank" class="relative w-4 h-4 flex items-center justify-center">
                <div class="absolute w-full h-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
                <div class="absolute h-full w-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
                <div class="w-1 h-1 bg-white"></div>
              </a>

              <div class={`absolute mb-2 w-max max-w-[240px] opacity-0 pointer-events-none group-hover:opacity-100 transition-all z-[100] ${bottom > 70 ? "top-6" : "bottom-full"} ${left > 70 ? "right-4" : "left-4"}`}>
                <div class="bg-black/95 border-l-2 border-cyan-500 p-3 shadow-2xl">
                   {ytId && <img src={`https://img.youtube.com/vi/${ytId}/mqdefault.jpg`} class="w-full aspect-video object-cover mb-2 border border-zinc-800" />}
                   <p class="text-white font-bold leading-tight">{work.title}</p>
                   <p class="text-[8px] text-cyan-500/50 mt-1 uppercase">Access ID: {work.artist}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <aside class="audio-hud">
    <div class="control-group">
      <label class="control-label">Master Volume</label>
      <input type="range" id="vol-fader" min="0" max="1" step="0.01" value="0.5">
    </div>
    
    <div class="control-group">
      <label class="control-label">Playback Speed</label>
      <input type="range" id="speed-fader" min="0.5" max="2" step="0.01" value="1.0">
    </div>

    <div class="control-group">
      <label class="control-label">Pitch Shift</label>
      <input type="range" id="pitch-fader" min="0.5" max="2" step="0.01" value="1.0">
    </div>

    <div class="mt-4 pt-4 border-t border-zinc-800">
      <div id="v-meter" class="h-1 w-full bg-zinc-900 overflow-hidden">
        <div id="v-bar" class="h-full bg-cyan-400 w-0 transition-all duration-100"></div>
      </div>
      <p class="text-[7px] text-zinc-600 mt-1 uppercase">Audio Signal Analysis</p>
    </div>
  </aside>
</div>

<script>
  let currentTag = null;
  let audioContext = null;
  let source = null;
  let audioNode = null;
  let gainNode = null;
  let isStarted = false;

  async function startExperience() {
    if (isStarted) return;
    isStarted = true;

    // 1. 靄（ブラー）を消す
    document.getElementById('start-overlay').classList.add('hidden');
    document.getElementById('map-target').classList.remove('is-blurred');

    // 2. オーディオ開始
    try {
      audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
      const response = await fetch('/SITE_th.mp3');
      const arrayBuffer = await response.arrayBuffer();
      const audioBuffer = await audioContext.decodeAudioData(arrayBuffer);

      source = audioContext.createBufferSource();
      source.buffer = audioBuffer;
      source.loop = true;

      gainNode = audioContext.createGain();
      gainNode.gain.value = 0.5;

      source.connect(gainNode);
      gainNode.connect(audioContext.destination);

      source.start(0);

      // 🎚️ フェーダー連動
      const volFader = document.getElementById('vol-fader') as HTMLInputElement;
      const speedFader = document.getElementById('speed-fader') as HTMLInputElement;
      const pitchFader = document.getElementById('pitch-fader') as HTMLInputElement;

      volFader.oninput = () => gainNode.gain.value = parseFloat(volFader.value);
      
      // 再生速度とピッチ（createBufferSourceのplaybackRateで制御）
      speedFader.oninput = () => source.playbackRate.value = parseFloat(speedFader.value);
      pitchFader.oninput = () => {
         // ピッチのみを独立させるのはWeb Audioでは複雑なため、
         // 一般的な「再生速度（テープ回転数）」の変化としてplaybackRateに統合
         source.playbackRate.value = parseFloat(pitchFader.value);
         speedFader.value = pitchFader.value;
      };

      // 📊 メーター簡易演出
      const vBar = document.getElementById('v-bar');
      setInterval(() => {
        const level = Math.random() * (gainNode.gain.value * 100);
        if(vBar) vBar.style.width = `${level}%`;
      }, 100);

    } catch (e) {
      console.error("Audio error:", e);
    }
  }

  function applyFilters() {
    const allWorks = document.querySelectorAll("[data-work]");
    const allBtns = document.querySelectorAll("button[id^='btn-']");
    allBtns.forEach(btn => btn.classList.remove('border-cyan-500', 'text-cyan-400'));
    const activeBtn = currentTag ? document.getElementById(`btn-${currentTag}`) : document.getElementById('btn-all');
    activeBtn?.classList.add('border-cyan-500', 'text-cyan-400');

    allWorks.forEach((el) => {
      const tags = ((el as HTMLElement).dataset.tags || "").split(",").map(t => t.trim()).filter(Boolean);
      if (!currentTag) {
        el.classList.remove('is-active', 'is-inactive');
      } else if (tags.includes(currentTag)) {
        el.classList.add('is-active'); el.classList.remove('is-inactive');
      } else {
        el.classList.add('is-inactive'); el.classList.remove('is-active');
      }
    });
  }

  (window as any).setTag = (tag) => {
    if (!isStarted) startExperience();
    currentTag = tag;
    applyFilters();
  };

  (window as any).startExperience = startExperience;
  document.addEventListener('DOMContentLoaded', applyFilters);
</script>

---
import { works } from '../data/works';
import '../styles/global.css';

// 🔥 データの準備：UID付与とフィルタ項目抽出
const mappedWorks = works.map((w, i) => ({ ...w, _uid: i }));
const allTags = [...new Set(works.flatMap(w => w.tags ?? []))].sort();
const allYears = [...new Set(works.map(w => String(w.year)))].sort().reverse();
---

<style>
  /* --------------------------------------------------
   * 🌫️ 全体デザイン・ブラー設定
   * -------------------------------------------------- */
  :global(body.is-blurred) { filter: blur(20px) saturate(0.5); pointer-events: none; overflow: hidden; }
  :global(body) { background-color: #020205; margin: 0; color: white; min-height: 100vh; transition: filter 0.4s; }

  #start-overlay {
    position: fixed; inset: 0; z-index: 9999; display: flex; flex-direction: column; gap: 16px;
    align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.95); cursor: pointer;
  }
  #start-overlay.hidden { opacity: 0; visibility: hidden; pointer-events: none; }

  .main-layout {
    display: grid; grid-template-columns: 1fr 300px; gap: 40px;
    max-width: 1400px; margin: 40px auto; opacity: 0; transition: opacity 1s;
  }
  :global(body:not(.is-blurred)) .main-layout { opacity: 1; }

  /* 🗺️ ポイントマップ・デザイン（維持） */
  [data-work] { position: absolute; transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.5s; z-index: 10; }
  [data-work].is-filtered-out { opacity: 0 !important; pointer-events: none; transform: scale(0); }
  
  .point-core { width: 6px; height: 6px; background: #3f3f46; border-radius: 1px; transition: all 0.4s; }
  [data-work].is-active .point-core { background: #fff; box-shadow: 0 0 15px 2px cyan; transform: scale(1.6); }

  /* 🗨️ ツールチップ・デザイン（維持・強化） */
  .work-tooltip {
    position: absolute; width: 220px; opacity: 0; pointer-events: none;
    transform: translateY(15px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: 200;
  }
  [data-work].show-info .work-tooltip { opacity: 1; pointer-events: auto; transform: translateY(0); }

  /* 📜 ロータリー（80px固定・同期用） */
  .rotary-container { position: relative; height: 320px; overflow: hidden; }
  .rotary-viewport { height: 100%; overflow-y: auto; scrollbar-width: none; scroll-behavior: smooth; }
  .rotary-viewport::-webkit-scrollbar { display: none; }
  .rotary-item {
    height: 80px; display: flex; align-items: center; padding: 0 24px;
    opacity: 0.1; transition: all 0.4s; cursor: pointer; border-left: 1px solid transparent;
  }
  .rotary-item.is-hidden { display: none; }
  .rotary-item.is-focused { opacity: 1; color: cyan; border-left: 1px solid cyan; background: linear-gradient(90deg, rgba(0,255,255,0.05) 0%, transparent 100%); }

  /* 🎚️ HUD・デザイン */
  .hud-panel { background: rgba(9, 9, 11, 0.6); border: 1px solid rgba(255, 255, 255, 0.05); backdrop-filter: blur(12px); }
</style>

<div id="start-overlay">
  <span class="border border-zinc-700 text-zinc-500 px-8 py-3 text-[10px] tracking-[0.6em] animate-pulse uppercase">Initialize System</span>
</div>

<div class="main-layout px-8">
  <div class="flex flex-col gap-6">
    <div class="hud-panel p-5 flex flex-col gap-4">
      <div class="flex flex-wrap gap-2">
        <button id="btn-tag-all" onclick="setFilter('tag', null)" class="text-[9px] px-3 py-1.5 border border-zinc-800 uppercase tracking-widest transition-all">All Types</button>
        {allTags.map(tag => <button id={`btn-tag-${tag}`} onclick={`setFilter('tag', '${tag}')`} class="text-[9px] px-3 py-1.5 border border-zinc-800 uppercase tracking-widest transition-all">{tag}</button>)}
      </div>
      <div class="flex flex-wrap gap-2">
        <button id="btn-year-all" onclick="setFilter('year', null)" class="text-[9px] px-3 py-1.5 border border-zinc-800 uppercase tracking-widest transition-all">All Time</button>
        {allYears.map(year => <button id={`btn-year-${year}`} onclick={`setFilter('year', '${year}')`} class="text-[9px] px-3 py-1.5 border border-zinc-800 uppercase tracking-widest transition-all">{year}</button>)}
      </div>
    </div>

    <div id="map-target" class="relative aspect-video bg-zinc-950 border border-zinc-800/50 overflow-hidden shadow-inner">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(cyan 1px, transparent 1px); background-size: 50px 50px;"></div>
      
      <div class="absolute inset-24">
        {mappedWorks.map((work) => {
          const left = ((work.x + 100) / 200) * 100;
          const bottom = ((work.y + 100) / 200) * 100;
          const ytId = work.url?.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=)([^#\&\?]*)/)?.[1];
          return (
            <div 
              data-work 
              data-uid={work._uid}
              data-tags={work.tags?.join(",") ?? ""} 
              data-year={work.year}
              style={`left: ${left}%; bottom: ${bottom}%;`}
              onmouseenter={`handlePointHover(${work._uid}, true)`}
              onmouseleave={`handlePointHover(${work._uid}, false)`}
              onclick={`syncWheelToMap(${work._uid})`}
            >
              <div class="group relative w-10 h-10 flex items-center justify-center cursor-pointer">
                <div class="point-core"></div>
              </div>

              <div class={`work-tooltip ${bottom > 70 ? 'top-12' : 'bottom-12'} ${left > 75 ? 'right-0' : 'left-0'}`}>
                <div class="bg-zinc-900 border border-cyan-500/30 p-2.5 shadow-2xl backdrop-blur-xl">
                  {ytId && <img src={`https://img.youtube.com/vi/${ytId}/mqdefault.jpg`} class="w-full aspect-video object-cover mb-2 grayscale hover:grayscale-0 transition-all duration-500" />}
                  <div class="flex justify-between items-start mb-1">
                    <p class="text-[7px] text-cyan-600 uppercase tracking-widest">{work.artist}</p>
                    <p class="text-[7px] text-zinc-600">{work.year}</p>
                  </div>
                  <p class="text-[11px] font-bold leading-tight line-clamp-2 tracking-tight text-zinc-200">{work.title}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-6">
    <aside class="hud-panel p-6 space-y-5">
      <div class="text-[8px] text-zinc-600 border-b border-zinc-800 pb-2 uppercase tracking-[0.3em]">Audio Interface</div>
      <div class="space-y-3">
        <div><label class="text-[7px] text-cyan-900 block mb-1 uppercase">Output Gain</label><input type="range" class="w-full h-[2px] bg-zinc-800 accent-cyan-600 appearance-none" id="vol-fader"></div>
        <div id="v-bar-container" class="h-[3px] w-full bg-zinc-900/50"><div id="v-bar" class="h-full bg-cyan-500/40 w-0 transition-all duration-75"></div></div>
      </div>
      <button id="play-pause-btn" class="w-full border border-cyan-900/20 text-cyan-800 text-[8px] py-2 uppercase tracking-[0.2em] hover:bg-cyan-500/5 transition-all">Interface Standby</button>
    </aside>

    <aside class="hud-panel overflow-hidden">
      <div class="px-5 py-3 border-b border-zinc-800 text-[8px] text-zinc-500 uppercase tracking-widest flex justify-between items-center">
        <span>Navigation Wheel</span>
        <span id="item-count" class="text-cyan-900">00</span>
      </div>
      <div class="rotary-container">
        <div id="rotary-viewport" class="rotary-viewport">
          <div style="height: 120px;"></div> <div id="rotary-list">
            {mappedWorks.map((work) => (
              <div class="rotary-item" data-uid={work._uid} onclick={`syncWheelToMap(${work._uid})`}>
                <div class="flex flex-col truncate">
                  <span class="text-[7px] opacity-40 uppercase tracking-tighter mb-0.5">{work.artist}</span>
                  <span class="text-[11px] leading-none font-bold tracking-tight">{work.title}</span>
                </div>
              </div>
            ))}
          </div>
          <div style="height: 120px;"></div> </div>
      </div>
    </aside>
  </div>
</div>

<script>
  let currentTag = null;
  let currentYear = null;
  let isStarted = false;
  let wheelActiveUid = null;
  let hoverActiveUid = null;

  const viewport = document.getElementById('rotary-viewport');
  const itemHeight = 80;

  // --------------------------------------------------
  // 🎯 同期 & 表示ロジック（優先順位制御）
  // --------------------------------------------------
  function updateDisplayState() {
    const allPoints = document.querySelectorAll('[data-work]');
    const activeUid = hoverActiveUid !== null ? hoverActiveUid : wheelActiveUid;

    allPoints.forEach(el => {
      const uid = parseInt(el.dataset.uid);
      const tags = (el.dataset.tags || "").split(",");
      const year = el.dataset.year;

      const isMatch = (!currentTag || tags.includes(currentTag)) && (!currentYear || year === currentYear);
      
      el.classList.toggle('is-filtered-out', !isMatch);
      el.classList.toggle('is-active', uid === wheelActiveUid);
      el.classList.toggle('show-info', isMatch && uid === activeUid);
    });

    document.querySelectorAll('.rotary-item').forEach(item => {
      const uid = parseInt(item.dataset.uid);
      item.classList.toggle('is-focused', uid === wheelActiveUid);
    });

    // カウント更新
    const visibleCount = document.querySelectorAll('.rotary-item:not(.is-hidden)').length;
    const countEl = document.getElementById('item-count');
    if(countEl) countEl.innerText = visibleCount.toString().padStart(2, '0');
  }

  // --------------------------------------------------
  // 📜 スクロール量に基づく数学的同期
  // --------------------------------------------------
  viewport.addEventListener('scroll', () => {
    hoverActiveUid = null; // スクロール中はホバーを解除
    
    const visibleItems = Array.from(document.querySelectorAll('.rotary-item:not(.is-hidden)'));
    if (visibleItems.length === 0) return;

    // スクロール位置から現在のインデックスを算出
    const index = Math.round(viewport.scrollTop / itemHeight);
    const safeIndex = Math.max(0, Math.min(index, visibleItems.length - 1));
    
    const newUid = parseInt(visibleItems[safeIndex].dataset.uid);
    if (wheelActiveUid !== newUid) {
      wheelActiveUid = newUid;
      updateDisplayState();
    }
  });

  window.handlePointHover = (uid, isEnter) => {
    hoverActiveUid = isEnter ? uid : null;
    updateDisplayState();
  };

  window.syncWheelToMap = (uid) => {
    const visibleItems = Array.from(document.querySelectorAll('.rotary-item:not(.is-hidden)'));
    const targetIdx = visibleItems.findIndex(item => parseInt(item.dataset.uid) === uid);
    if (targetIdx !== -1) {
      viewport.scrollTo({ top: targetIdx * itemHeight, behavior: 'smooth' });
    }
  };

  // --------------------------------------------------
  // ⚡ フィルタリング（連動反映）
  // --------------------------------------------------
  window.setFilter = (type, value) => {
    if (!isStarted) startExperience();
    
    if (type === 'tag') currentTag = value;
    if (type === 'year') currentYear = value;

    // ロータリーの表示・非表示を更新
    document.querySelectorAll('.rotary-item').forEach(item => {
      const el = document.querySelector(`[data-work][data-uid="${item.dataset.uid}"]`);
      const tags = el.dataset.tags.split(',');
      const year = el.dataset.year;
      const isMatch = (!currentTag || tags.includes(currentTag)) && (!currentYear || year === currentYear);
      item.classList.toggle('is-hidden', !isMatch);
    });

    // ボタンの外観更新
    document.querySelectorAll("button[id^='btn-']").forEach(btn => btn.style.borderColor = '');
    const tagBtn = currentTag ? document.getElementById(`btn-tag-${currentTag}`) : document.getElementById('btn-tag-all');
    if (tagBtn) tagBtn.style.borderColor = 'cyan';
    const yearBtn = currentYear ? document.getElementById(`btn-year-${currentYear}`) : document.getElementById('btn-year-all');
    if (yearBtn) yearBtn.style.borderColor = 'cyan';

    updateDisplayState();
    viewport.scrollTo({ top: 0, behavior: 'auto' });
  };

  // --------------------------------------------------
  // 🔊 HUD: ビジュアライザー（デザイン継承）
  // --------------------------------------------------
  const vBar = document.getElementById('v-bar');
  setInterval(() => {
    if (!isStarted || !vBar) return;
    const level = Math.random() * 60 + 10;
    vBar.style.width = `${level}%`;
  }, 120);

  // 始動
  function startExperience() {
    if (isStarted) return;
    isStarted = true;
    document.getElementById('start-overlay').classList.add('hidden');
    document.body.classList.remove('is-blurred');
    const firstItem = document.querySelector('.rotary-item:not(.is-hidden)');
    if (firstItem) wheelActiveUid = parseInt(firstItem.dataset.uid);
    updateDisplayState();
  }

  document.getElementById('start-overlay').addEventListener('click', startExperience);
</script>

---
import { works } from '../data/works';
import '../styles/global.css';

const allTags = [...new Set(works.flatMap(w => w.tags ?? []))].sort();
const allYears = [...new Set(works.map(w => String(w.year)))].sort().reverse();
---

<style>
  :global(body) {
    background-color: #020205;
    margin: 0;
    color: white;
    min-height: 100vh;
  }

  .main-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 20px;
    max-width: 1400px;
    margin: 20px auto;
    padding: 0 20px;
    font-family: monospace;
  }

  .map-container {
    position: relative;
  }

  [data-work] {
    position: absolute;
    transform: translate(-50%, 50%);
  }

  /* -------------------------------
     Rotary Wheel
  -------------------------------- */
  .rotary-container {
    position: relative;
    width: 260px;
    height: 260px;
    border: 1px solid rgba(34, 211, 238, 0.1);
    overflow: hidden;
  }

  .rotary-wheel {
    position: absolute;
    inset: 0;
    transform-origin: center;
    transition: transform 0.6s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .rotary-item {
    position: absolute;
    left: 50%;
    top: 50%;
    transform-origin: center center;
    font-size: 10px;
    color: #71717a;
    white-space: nowrap;
    pointer-events: none;
    text-align: center;
    width: 140px;
    margin-left: -70px;
  }

  .rotary-item.is-active {
    color: #22d3ee;
    font-weight: bold;
    text-shadow: 0 0 8px rgba(34, 211, 238, 0.5);
  }

  .rotary-center {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .rotary-active {
    font-size: 10px;
    color: #22d3ee;
    border: 1px solid rgba(34, 211, 238, 0.3);
    padding: 6px 10px;
    background: rgba(0, 0, 0, 0.6);
  }
</style>

<div class="main-layout">
  <div class="map-container">
    {works.map((work) => {
      const left = ((work.x + 100) / 200) * 100;
      const bottom = ((work.y + 100) / 200) * 100;
      return (
        <div 
          data-work
          style={`left:${left}%; bottom:${bottom}%`}
        >
          ●
        </div>
      );
    })}
  </div>

  <aside>
    <div class="rotary-container">
      <div id="rotary-wheel" class="rotary-wheel">
        {works.map((work, i) => (
          <div class="rotary-item" data-index={i}>
            {work.title}
          </div>
        ))}
      </div>

      <div class="rotary-center">
        <div id="rotary-active" class="rotary-active">SELECT</div>
      </div>
    </div>
  </aside>
</div>

<script>
  let rotaryIndex = 0;
  let rotaryItems = [];
  let total = 0;

  function initRotary() {
    const wheel = document.getElementById('rotary-wheel');
    if (!wheel) return;

    rotaryItems = Array.from(wheel.querySelectorAll('.rotary-item'));
    total = rotaryItems.length;

    const step = 360 / total;
    const radius = 100;

    // 円形配置
    rotaryItems.forEach((el, i) => {
      const angle = step * i;
      el.style.transform = `
        rotate(${angle}deg)
        translateY(-${radius}px)
        rotate(${-angle}deg)
      `;
    });

    update();
  }

  function update() {
    const wheel = document.getElementById('rotary-wheel');
    const display = document.getElementById('rotary-active');
    if (!wheel) return;

    const step = 360 / total;
    const angle = -rotaryIndex * step;

    wheel.style.transform = `rotate(${angle}deg)`;

    rotaryItems.forEach(el => el.classList.remove('is-active'));

    const active = rotaryItems[rotaryIndex];
    if (active) {
      active.classList.add('is-active');
      if (display) display.innerText = active.innerText;
    }
  }

  function rotate(dir) {
    rotaryIndex += dir;

    if (rotaryIndex < 0) rotaryIndex = total - 1;
    if (rotaryIndex >= total) rotaryIndex = 0;

    update();
  }

  document.addEventListener('DOMContentLoaded', () => {
    requestAnimationFrame(initRotary);

    document.addEventListener('wheel', (e) => {
      if (Math.abs(e.deltaY) < 10) return;

      if (e.deltaY > 0) rotate(1);
      else rotate(-1);
    }, { passive: true });
  });
</script>

---
import { works } from '../data/works';
import '../styles/global.css';

// 📊 データ準備
const allTags = [...new Set(works.flatMap(w => w.tags ?? []))].sort();
const allYears = [...new Set(works.map(w => String(w.year)))].sort().reverse();

const mappedWorks = works.map((w, i) => ({ ...w, _uid: i }));
// ホイール用：時系列順（新しい順）
const wheelWorks = [...mappedWorks].sort((a, b) => Number(b.year) - Number(a.year));
---

<style>
  :global(body.is-blurred) { filter: blur(20px) saturate(0.5); pointer-events: none; overflow: hidden; }
  :global(body) { background-color: #020205; margin: 0; color: white; min-height: 100vh; transition: filter 0.4s ease; }

  #start-overlay {
    position: fixed; inset: 0; z-index: 9999; display: flex; flex-direction: column; gap: 16px;
    align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.95); cursor: pointer;
  }
  #start-overlay.hidden { opacity: 0; visibility: hidden; }

  .contact-bar { display: flex; justify-content: flex-end; padding: 10px 20px; font-size: 10px; border-bottom: 1px solid rgba(34, 211, 238, 0.1); }

  .main-layout {
    display: grid; grid-template-columns: 1fr 280px; gap: 20px;
    max-width: 1400px; margin: 20px auto; font-family: 'JetBrains Mono', monospace;
    opacity: 0; transition: opacity 1s ease 0.5s;
  }
  :global(body:not(.is-blurred)) .main-layout { opacity: 1; }

  /* 🗺️ マップ要素の状態定義 */
  .map-container { perspective: 1200px; transform-style: preserve-3d; position: relative; }
  [data-work] { position: absolute; transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1); transform: translate(-50%, 50%); }
  
  /* アクティブ（選択中） */
  [data-work].is-active { 
    opacity: 1; z-index: 500 !important; 
    transform: translate(-50%, 50%) translateZ(80px) scale(1.3);
    filter: drop-shadow(0 0 15px rgba(34, 211, 238, 0.8));
  }
  /* 非選択（通常） */
  [data-work].is-inactive { opacity: 0.3; z-index: 10; transform: translate(-50%, 50%) translateZ(0) scale(1); }
  /* フィルタ除外 */
  [data-work].is-filtered-out { opacity: 0.05 !important; pointer-events: none; transform: translate(-50%, 50%) translateZ(-100px) scale(0.6); }

  /* 🎚️ 右パネル：HUD & ホイール */
  .audio-hud { 
    display: flex; flex-direction: column; gap: 10px; padding: 16px; 
    background: rgba(9, 9, 11, 0.9); border: 1px solid rgba(34, 211, 238, 0.1); 
    height: calc(100vh - 100px); position: sticky; top: 20px; overflow-y: auto;
  }
  .control-group { display: flex; flex-direction: column; gap: 4px; }
  .control-label { font-size: 7px; color: #22d3ee; text-transform: uppercase; letter-spacing: 0.1em; }
  input[type="range"] { appearance: none; background: #18181b; height: 2px; outline: none; width: 100%; margin: 8px 0; }
  input[type="range"]::-webkit-slider-thumb { appearance: none; width: 6px; height: 6px; background: #22d3ee; border-radius: 50%; cursor: pointer; }

  /* 📜 Chrono-Rotary Wheel (時系列リスト) */
  .rotary-container {
    position: relative; height: 200px; margin: 15px 0;
    border-top: 1px solid rgba(34, 211, 238, 0.1);
    border-bottom: 1px solid rgba(34, 211, 238, 0.1);
    mask-image: linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
    overflow: hidden;
  }
  .rotary-viewport { height: 100%; overflow-y: auto; scrollbar-width: none; }
  .rotary-viewport::-webkit-scrollbar { display: none; }
  
  .rotary-item { 
    height: 32px; display: flex; align-items: center; position: absolute; width: 100%;
    font-size: 8px; color: #52525b; transition: all 0.3s ease;
    opacity: 0.2; cursor: pointer; padding: 0 8px; white-space: nowrap;
  }
  .rotary-item.is-focused { opacity: 1; color: #22d3ee; font-weight: bold; transform: scale(1.05); }
  .focus-line { position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: rgba(34, 211, 238, 0.3); pointer-events: none; transform: translateY(-50%); }

  .status-bar { font-size: 7px; color: #3f3f46; display: flex; justify-content: space-between; margin-top: auto; border-top: 1px solid #18181b; pt-2; }
</style>

<div id="start-overlay">
  <span class="text-cyan-400 text-[10px] tracking-[0.4em] animate-pulse border border-cyan-400/50 px-4 py-2">INITIALIZE CORE</span>
</div>

<div class="contact-bar">
  <div class="contact-link" onclick="navigator.clipboard.writeText('info@corecreative.jp')">
    <span class="text-zinc-500">SYSTEM_CONTACT: info@corecreative.jp</span>
  </div>
</div>

<div class="max-w-4xl mx-auto pt-6 px-4 space-y-4">
  <div class="flex flex-wrap gap-2 text-[9px]">
    <button id="btn-tag-all" onclick="setTag(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 uppercase">All Tags</button>
    {allTags.map(tag => (
      <button id={`btn-tag-${tag}`} onclick={`setTag("${tag}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 uppercase">{tag}</button>
    ))}
  </div>
  <div class="flex flex-wrap gap-2 text-[9px]">
    <button id="btn-year-all" onclick="setYear(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 uppercase">All Years</button>
    {allYears.map(year => (
      <button id={`btn-year-${year}`} onclick={`setYear("${year}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 uppercase">{year}</button>
    ))}
  </div>
</div>

<div class="main-layout">
  <div class="relative aspect-square px-4">
    <div id="map-target" class="map-container w-full h-full bg-zinc-950/40 border border-zinc-800 overflow-hidden font-mono text-[10px]">
      <div class="absolute inset-16 sm:inset-24">
        {mappedWorks.map((work) => {
          const left = ((work.x + 100) / 200) * 100;
          const bottom = ((work.y + 100) / 200) * 100;
          return (
            <div 
              data-work 
              data-uid={work._uid}
              data-tags={work.tags?.join(",") ?? ""} 
              data-year={work.year}
              class="group absolute cursor-crosshair is-inactive" 
              style={`left: ${left}%; bottom: ${bottom}%;`}
              onclick={`syncWheelToMap(${work._uid})`}
            >
              <div class="relative w-4 h-4 flex items-center justify-center">
                <div class="absolute w-full h-[1px] bg-zinc-700 group-hover:bg-cyan-500"></div>
                <div class="absolute h-full w-[1px] bg-zinc-700 group-hover:bg-cyan-500"></div>
                <div class="w-1.5 h-1.5 bg-white shadow-[0_0_8px_white]"></div>
              </div>

              <div class={`absolute mb-2 w-[220px] z-[999] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-300 ${bottom > 70 ? 'top-6' : 'bottom-full'} ${left > 70 ? 'right-4' : 'left-4'}`}>
                <div class="bg-black/95 border-l-2 border-cyan-500 p-3 shadow-2xl backdrop-blur-xl border border-zinc-800">
                  <p class="text-white font-bold leading-tight mb-1">{work.title}</p>
                  <p class="text-[8px] text-zinc-500 mb-2">{work.year} / {work.tags?.join(", ")}</p>
                  <a href={work.url} target="_blank" class="block text-[8px] text-zinc-400 border border-zinc-800 px-2 py-1 hover:bg-cyan-900/30 hover:text-cyan-400 transition-colors">
                    VIEW DATA →
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <aside class="audio-hud">
    <div class="control-group"><label class="control-label">Master Gain</label><input type="range" id="vol-fader" min="0" max="1" step="0.01" value="0.2"></div>
    <div class="control-group"><label class="control-label">Playback Speed</label><input type="range" id="speed-fader" min="0.1" max="4" step="0.1" value="1"></div>
    
    <div class="hud-divider h-[1px] bg-zinc-800 my-1"></div>
    
    <div class="rotary-container">
      <div class="focus-line"></div>
      <div id="rotary" class="rotary-viewport">
        <div id="rotary-dummy" style="height: 100000px;"></div>
        <div id="rotary-list" class="absolute top-0 left-0 w-full pointer-events-none">
          {wheelWorks.map((work) => (
            <div class="rotary-item pointer-events-auto" data-uid={work._uid} onclick={`syncWheelToMap(${work._uid})`}>
              <span class="w-8 font-mono text-[7px] text-zinc-600">{work.year}</span>
              <span class="truncate tracking-tighter">{work.title}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="hud-divider h-[1px] bg-zinc-800 my-1"></div>

    <div class="control-group"><label class="control-label">FM Intensity</label><input type="range" id="fm-int" min="0" max="1000" value="200"></div>
    <div class="control-group"><label class="control-label">FM Freq</label><input type="range" id="fm-freq" min="0.1" max="50" step="0.1" value="5"></div>
    <div class="control-group"><label class="control-label">Feedback</label><input type="range" id="fb-level" min="0" max="0.9" step="0.01" value="0.4"></div>
    
    <button id="play-pause-btn" class="mt-4 w-full border border-zinc-800 text-zinc-500 text-[8px] py-1 hover:text-cyan-400 hover:border-cyan-900 transition-all">PAUSE ENGINE</button>

    <div class="status-bar">
      <span id="sys-time">TIME: 00:00:00</span>
      <span id="sys-load">LOAD: 0ms</span>
    </div>
  </aside>
</div>

<script>
  let currentTag = null;
  let currentYear = null;
  let isStarted = false;
  let wheelActiveUid = null;

  // --------------------------------------------------
  // 🔄 フィルタ・状態管理
  // --------------------------------------------------
  function applyGlobalStates() {
    const allWorks = document.querySelectorAll("[data-work]");
    
    allWorks.forEach((el) => {
      const tags = (el.dataset.tags || "").split(",").map(t => t.trim()).filter(Boolean);
      const year = el.dataset.year;
      const uid = parseInt(el.dataset.uid);
      
      const tagMatch = !currentTag || tags.includes(currentTag);
      const yearMatch = !currentYear || year === currentYear;

      if (!tagMatch || !yearMatch) {
        el.classList.add('is-filtered-out');
        el.classList.remove('is-active', 'is-inactive');
      } else {
        el.classList.remove('is-filtered-out');
        if (uid === wheelActiveUid) {
          el.classList.add('is-active');
          el.classList.remove('is-inactive');
        } else {
          el.classList.add('is-inactive');
          el.classList.remove('is-active');
        }
      }
    });

    // ボタン外観更新
    document.querySelectorAll("button").forEach(btn => btn.classList.remove('border-cyan-500', 'text-cyan-400'));
    if (currentTag) document.getElementById(`btn-tag-${currentTag}`)?.classList.add('border-cyan-500', 'text-cyan-400');
    else document.getElementById('btn-tag-all')?.classList.add('border-cyan-500', 'text-cyan-400');
    
    if (currentYear) document.getElementById(`btn-year-${currentYear}`)?.classList.add('border-cyan-500', 'text-cyan-400');
    else document.getElementById('btn-year-all')?.classList.add('border-cyan-500', 'text-cyan-400');
  }

  window.setTag = (tag) => { if(!isStarted) startExperience(); currentTag = tag; applyGlobalStates(); };
  window.setYear = (year) => { if(!isStarted) startExperience(); currentYear = year; applyGlobalStates(); };

  // --------------------------------------------------
  // 📜 Rotary Wheel Logic
  // --------------------------------------------------
  const rotary = document.getElementById('rotary');
  const list = document.getElementById('rotary-list');
  const itemHeight = 32;
  const containerHeight = 200;

  function initWheel() {
    if (!rotary || !list) return;
    const items = Array.from(list.children);
    const numItems = items.length;
    const totalHeight = numItems * itemHeight;
    const centerPos = Math.floor(50000 / itemHeight) * itemHeight;
    
    rotary.scrollTop = centerPos;

    const updateWheel = () => {
      const currentScroll = rotary.scrollTop;
      const scrollY = currentScroll - centerPos;
      const activeIndex = ((Math.round(scrollY / itemHeight) % numItems) + numItems) % numItems;

      items.forEach((item, i) => {
        const wrappedPos = (((i * itemHeight - scrollY) % totalHeight) + totalHeight) % totalHeight;
        const offset = (containerHeight / 2) - (itemHeight / 2);
        item.style.transform = `translateY(${currentScroll + wrappedPos - offset}px)`;
        
        if (i === activeIndex) {
          item.classList.add('is-focused');
          wheelActiveUid = parseInt(item.dataset.uid);
        } else {
          item.classList.remove('is-focused');
        }
      });
      applyGlobalStates();
    };

    rotary.addEventListener('scroll', updateWheel, { passive: true });
    updateWheel();

    window.syncWheelToMap = (uid) => {
      if (!isStarted) startExperience();
      const targetIdx = items.findIndex(item => parseInt(item.dataset.uid) === uid);
      if (targetIdx === -1) return;

      const currentScroll = rotary.scrollTop;
      const currentIdx = ((Math.round((currentScroll - centerPos) / itemHeight) % numItems) + numItems) % numItems;
      
      let diff = targetIdx - currentIdx;
      if (diff > numItems / 2) diff -= numItems;
      if (diff < -numItems / 2) diff += numItems;

      rotary.scrollTo({ top: currentScroll + (diff * itemHeight), behavior: 'smooth' });
    };
  }

  // --------------------------------------------------
  // 🎬 システム初期化
  // --------------------------------------------------
  async function startExperience() {
    if (isStarted) return;
    isStarted = true;
    document.getElementById('start-overlay').classList.add('hidden');
    document.body.classList.remove('is-blurred');
    
    // 既存のオーディオ初期化（WorksMap_001.astroのロジック）をここに記述...
    // 今回は表示の復旧を優先しています。
  }

  document.addEventListener('DOMContentLoaded', () => {
    initWheel();
    document.getElementById('start-overlay').addEventListener('click', startExperience);
    
    // ステータスバー更新
    setInterval(() => {
      const timeEl = document.getElementById('sys-time');
      if(timeEl) timeEl.innerText = `TIME: ${new Date().toLocaleTimeString('ja-JP', { hour12: false })}`;
    }, 1000);
    const loadEl = document.getElementById('sys-load');
    if(loadEl) loadEl.innerText = `LOAD: ${Math.round(performance.now())}ms`;
  });
</script>

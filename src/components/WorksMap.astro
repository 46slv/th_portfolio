---
import { works } from '../data/works';
import '../styles/global.css';
---

<div class="relative w-full max-w-4xl mx-auto aspect-square bg-zinc-950 border border-zinc-800 overflow-hidden font-mono text-[10px] sm:text-xs selection:bg-cyan-500/30">
  <div class="absolute inset-0 opacity-20" 
       style="background-image: radial-gradient(circle, #27272a 1px, transparent 1px); background-size: 20px 20px;">
  </div>

  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-full h-[1px] bg-zinc-800"></div>
    <div class="absolute h-full w-[1px] bg-zinc-800"></div>
  </div>

  <div class="absolute top-6 left-1/2 -translate-x-1/2 text-zinc-600 tracking-[0.2em] uppercase font-black">Maniac [+]</div>
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-zinc-600 tracking-[0.2em] uppercase font-black">Popular [-]</div>
  <div class="absolute left-6 top-1/2 -translate-y-1/2 -rotate-90 text-zinc-600 tracking-[0.2em] uppercase font-black origin-left">Electro [L]</div>
  <div class="absolute right-6 top-1/2 -translate-y-1/2 rotate-90 text-zinc-600 tracking-[0.2em] uppercase font-black origin-right">Acoustic [R]</div>

  <div class="absolute inset-16 sm:inset-24">
    {works.map((work) => {
      const left = ((work.x + 100) / 200) * 100;
      const bottom = ((work.y + 100) / 200) * 100;

      return (
        <div 
          class="group absolute -translate-x-1/2 translate-y-1/2 cursor-crosshair"
          style={`left: ${left}%; bottom: ${bottom}%;`}
        >
          <div class="relative w-4 h-4 flex items-center justify-center">
            <div class="absolute w-full h-[1px] bg-zinc-600 group-hover:bg-cyan-400 transition-colors"></div>
            <div class="absolute h-full w-[1px] bg-zinc-600 group-hover:bg-cyan-400 transition-colors"></div>
            <div class="w-1 h-1 bg-white group-hover:scale-150 transition-transform"></div>
          </div>
          
          <div class="absolute bottom-full left-4 mb-2 w-max max-w-[180px] opacity-0 group-hover:opacity-100 pointer-events-none transition-all duration-200 translate-y-2 group-hover:translate-y-0 z-10">
            <div class="bg-black/90 border-l-2 border-cyan-500 p-3 backdrop-blur-md">
              <p class="text-[8px] text-cyan-500/70 mb-1 tracking-tighter">ID: {work.artist.toUpperCase()}</p>
              <p class="text-white font-bold leading-tight mb-2 tracking-tight">{work.title}</p>
              <a href={work.url} class="inline-block text-[9px] text-zinc-400 pointer-events-auto hover:text-white border border-zinc-700 px-2 py-1 transition-colors uppercase tracking-widest">
                Access Data _
              </a>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</div>
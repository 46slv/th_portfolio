---
import { works } from '../data/works';
import '../styles/global.css';

const allTags = [...new Set(works.flatMap(w => w.tags ?? []))];
---

<style>
  /* 🔵 既存のスタイル（維持） */
  .map-container {
    perspective: 1200px;
    transform-style: preserve-3d;
    position: relative;
    isolation: isolate;
  }

  @keyframes float {
    0%, 100% { transform: translate(-50%, 50%) rotate(0deg); }
    33% { transform: translate(calc(-50% + 4px), calc(50% - 6px)) rotate(1deg); }
    66% { transform: translate(calc(-50% - 3px), calc(50% - 2px)) rotate(-1deg); }
  }

  [data-work] {
    position: absolute;
    transition: opacity 0.6s, transform 0.6s, filter 0.6s;
    will-change: transform, opacity;
    transform: translate(-50%, 50%) translateZ(0px);
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  /* 🔴 追加：右側HUDレイアウト */
  .main-layout {
    display: grid;
    grid-template-columns: 1fr 300px; /* 左：グラフ / 右：HUD */
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
    font-family: 'JetBrains Mono', monospace;
  }

  .hud-side-panel {
    position: relative;
    border-left: 1px solid rgba(34, 211, 238, 0.2);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  /* 巨大な回転ホイール（円弧） */
  .wheel-rail {
    position: absolute;
    right: -900px;
    top: 50%;
    transform: translateY(-50%);
    width: 1800px;
    height: 1800px;
    border-radius: 50%;
    border: 1px solid rgba(34, 211, 238, 0.1);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .wheel-entry {
    position: absolute;
    left: 20px;
    top: 50%;
    width: 260px;
    transform-origin: 900px center;
    transition: all 0.4s;
    opacity: 0.2;
    font-[9px];
  }

  .wheel-entry.is-active {
    opacity: 1;
    color: #22d3ee;
    transform: rotate(0deg) translateX(-20px);
    filter: drop-shadow(0 0 8px #22d3ee);
  }

  /* 十字レティクル（グラフ内を移動） */
  #target-reticle {
    position: absolute;
    width: 50px;
    height: 50px;
    border: 1px solid rgba(34, 211, 238, 0.5);
    pointer-events: none;
    z-index: 150;
    transform: translate(-50%, 50%);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #target-reticle::before { content: ''; position: absolute; width: 100%; height: 1px; top: 50%; left: 0; background: #22d3ee; }
  #target-reticle::after { content: ''; position: absolute; width: 1px; height: 100%; left: 50%; top: 0; background: #22d3ee; }
</style>

<div class="max-w-4xl mx-auto mb-4 flex flex-wrap gap-2 text-xs">
  <button id="btn-all" onclick="setTag(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 transition-all">ALL</button>
  {allTags.map(tag => (
    <button id={`btn-${tag}`} onclick={`setTag("${tag}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 transition-all">{tag}</button>
  ))}
</div>

<div class="main-layout">
  <div class="map-container relative w-full aspect-square bg-zinc-950 border border-zinc-800 overflow-hidden font-mono text-[10px]">
    <div id="target-reticle" class="opacity-0"></div> <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #27272a 1px, transparent 1px); background-size: 20px 20px;"></div>
    
    <div class="absolute inset-16 sm:inset-24">
      {works.map((work, index) => {
        const left = ((work.x + 100) / 200) * 100;
        const bottom = ((work.y + 100) / 200) * 100;
        return (
          <div 
            data-work
            data-index={index}
            data-tags={work.tags?.join(",") ?? ""}
            class="group absolute cursor-crosshair animate-float"
            style={`left: ${left}%; bottom: ${bottom}%; animation-delay: ${index * 0.2}s;`}
            onclick={`focusIndex(${index})`}
          >
            <div class="w-3 h-3 border border-zinc-600 group-hover:border-cyan-400 transition-colors bg-black/50 flex items-center justify-center">
               <div class="w-0.5 h-0.5 bg-white"></div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <aside class="hud-side-panel">
    <div class="p-4 bg-zinc-900/50 border border-cyan-900/30 space-y-4 z-10">
      <div id="hud-thumb" class="w-full aspect-video bg-black overflow-hidden border border-zinc-800"></div>
      <div>
        <p id="hud-id" class="text-[8px] text-cyan-500/50 uppercase">Data Entry</p>
        <h2 id="hud-title" class="text-xs font-bold text-white uppercase truncate">Ready</h2>
      </div>
      <a id="hud-link" href="#" target="_blank" class="block text-center border border-cyan-500 py-2 text-[9px] text-cyan-400 hover:bg-cyan-500 hover:text-black transition-all font-bold">ACCESS DATA</a>
    </div>

    <div class="flex-1 relative pointer-events-none">
      <div id="wheel-rail" class="wheel-rail">
        {works.map((work, i) => (
          <div class="wheel-entry text-[9px] uppercase font-black" data-wheel-index={i}>
            {work.title}
          </div>
        ))}
      </div>
      <div class="absolute left-0 top-1/2 -translate-y-1/2 w-10 h-[1px] bg-cyan-400 shadow-[0_0_10px_#22d3ee]"></div>
    </div>
  </aside>
</div>

<script define:vars={{ works }}>
  let activeIndex = 0;

  function focusIndex(index) {
    activeIndex = Math.max(0, Math.min(index, works.length - 1));
    updateHUD();
  }

  function updateHUD() {
    const data = works[activeIndex];
    
    // 1. マップ上のレティクル移動
    const target = document.querySelector(`[data-work][data-index="${activeIndex}"]`);
    const reticle = document.getElementById("target-reticle");
    if (target) {
      reticle.style.opacity = "1";
      reticle.style.left = target.style.left;
      reticle.style.bottom = target.style.bottom;
    }

    // 2. ホイール回転
    const angleStep = 8;
    const rail = document.getElementById("wheel-rail");
    rail.style.transform = `translateY(-50%) rotate(${activeIndex * -angleStep}deg)`;
    
    document.querySelectorAll(".wheel-entry").forEach((item, i) => {
      item.classList.toggle("is-active", i === activeIndex);
      item.style.transform = `rotate(${i * angleStep}deg)`;
    });

    // 3. 情報更新
    document.getElementById("hud-title").innerText = data.title;
    document.getElementById("hud-id").innerText = `ID: ${data.artist}`;
    document.getElementById("hud-link").href = data.url;
    const ytId = data.url?.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=)([^#\&\?]*)/)?.[1];
    document.getElementById("hud-thumb").innerHTML = ytId 
      ? `<img src="https://img.youtube.com/vi/${ytId}/mqdefault.jpg" class="w-full h-full object-cover" />`
      : "";
  }

  // 入力
  window.addEventListener("wheel", (e) => {
    if (Math.abs(e.deltaY) < 10) return;
    e.deltaY > 0 ? focusIndex(activeIndex + 1) : focusIndex(activeIndex - 1);
  }, { passive: true });

  window.addEventListener("keydown", (e) => {
    if (["ArrowUp", "ArrowLeft"].includes(e.key)) focusIndex(activeIndex - 1);
    if (["ArrowDown", "ArrowRight"].includes(e.key)) focusIndex(activeIndex + 1);
  });

  window.focusIndex = focusIndex;
  document.addEventListener("DOMContentLoaded", () => focusIndex(0));
</script>

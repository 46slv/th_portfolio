---
import { works } from '../data/works';
import '../styles/global.css';

const allTags = [...new Set(works.flatMap(w => w.tags ?? []))];
---

<style>
  /* 🔵 追加：HUDヘッダーとホイールのスタイル */
  .hud-top-panel {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 15px;
    border: 1px solid rgba(34, 211, 238, 0.2);
    background: rgba(0, 0, 0, 0.4);
    padding: 15px;
    font-family: 'JetBrains Mono', monospace;
  }

  .wheel-container {
    position: relative;
    height: 60px;
    overflow: hidden;
    border-top: 1px solid rgba(34, 211, 238, 0.1);
    mask-image: linear-gradient(90deg, transparent, black 20%, black 80%, transparent);
  }

  .wheel-track {
    position: absolute;
    left: 50%;
    top: 300px; /* 巨大な円の半径 */
    transform: translateX(-50%) rotate(0deg);
    transition: transform 0.5s cubic-bezier(0.19, 1, 0.22, 1);
    transform-style: preserve-3d;
  }

  .wheel-item {
    position: absolute;
    left: 50%;
    top: 0;
    width: 180px;
    transform-origin: center -300px;
    text-align: center;
    transition: all 0.3s;
    opacity: 0.3;
    pointer-events: none;
  }

  .wheel-item.is-active {
    opacity: 1;
    color: #22d3ee;
    filter: drop-shadow(0 0 8px rgba(34, 211, 238, 0.8));
    transform: translateX(-50%) translateY(-10px) scale(1.1);
  }

  /* 🎯 マップ内のレティクル（十字線） */
  #map-reticle {
    position: absolute;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(34, 211, 238, 0.4);
    pointer-events: none;
    z-index: 50;
    transform: translate(-50%, 50%);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #map-reticle::before, #map-reticle::after {
    content: ''; position: absolute; background: #22d3ee;
  }
  #map-reticle::before { width: 100%; height: 1px; top: 50%; left: 0; }
  #map-reticle::after { width: 1px; height: 100%; left: 50%; top: 0; }

  /* 既存のスタイル維持 */
  .map-container {
    perspective: 1200px;
    transform-style: preserve-3d;
    position: relative;
    isolation: isolate;
  }

  [data-work] {
    position: absolute;
    transition: opacity 0.6s, transform 0.6s, filter 0.6s;
    will-change: transform, opacity;
    transform: translate(-50%, 50%) translateZ(0px);
  }

  [data-work].is-active {
    opacity: 1 !important;
    z-index: 100;
    transform: translate(-50%, 50%) translateZ(80px) scale(1.1);
    filter: drop-shadow(0 0 10px rgba(34, 211, 238, 0.8));
  }
</style>

<div class="max-w-4xl mx-auto hud-top-panel">
  <div class="flex gap-4 items-center h-24">
    <div id="hud-thumb" class="w-32 aspect-video bg-zinc-900 border border-cyan-900 overflow-hidden shrink-0 shadow-lg">
      </div>
    <div class="flex-1 min-w-0">
      <div id="hud-id" class="text-[8px] text-cyan-500/50 tracking-widest uppercase">Select Data Point</div>
      <h2 id="hud-title" class="text-lg font-black text-white truncate uppercase tracking-tighter">System Initialized</h2>
      <div id="hud-tags" class="flex gap-1 mt-1 overflow-hidden"></div>
    </div>
  </div>

  <div class="wheel-container">
    <div id="wheel-track" class="wheel-track">
      {works.map((work, i) => (
        <div class="wheel-item text-[10px] uppercase font-bold" data-index={i}>
          {work.title}
        </div>
      ))}
    </div>
    <div class="absolute left-1/2 top-0 -translate-x-1/2 w-px h-full bg-cyan-500/30"></div>
  </div>
</div>

<div class="max-w-4xl mx-auto mb-4 flex flex-wrap gap-2 text-xs">
  <button id="btn-all" onclick="setTag(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 transition-all uppercase">All</button>
  {allTags.map(tag => (
    <button id={`btn-${tag}`} onclick={`setTag("${tag}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 transition-all uppercase">{tag}</button>
  ))}
</div>

<div class="map-container relative w-full max-w-4xl mx-auto aspect-square bg-zinc-950 border border-zinc-800 overflow-hidden font-mono text-[10px] selection:bg-cyan-500/30">
  
  <div id="map-reticle" class="opacity-0"></div>

  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #27272a 1px, transparent 1px); background-size: 20px 20px;"></div>
  
  <div class="absolute inset-16 sm:inset-24">
    {works.map((work, index) => {
      const left = ((work.x + 100) / 200) * 100;
      const bottom = ((work.y + 100) / 200) * 100;

      return (
        <div 
          data-work
          data-index={index}
          data-tags={work.tags?.join(",") ?? ""}
          class="group absolute cursor-crosshair"
          style={`left: ${left}%; bottom: ${bottom}%; z-index: ${Math.round(bottom)};`}
          onclick={`focusItem(${index})`}
        >
          <div class="relative w-4 h-4 flex items-center justify-center group-hover:scale-125 transition-transform">
            <div class="absolute w-full h-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
            <div class="absolute h-full w-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
            <div class="w-1 h-1 bg-white"></div>
          </div>
        </div>
      );
    })}
  </div>
</div>

<script define:vars={{ works }}>
  let activeIndex = 0;
  let currentTag = null;

  function getYoutubeId(url) {
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url?.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
  }

  function focusItem(index) {
    activeIndex = Math.max(0, Math.min(index, works.length - 1));
    updateUI();
  }

  function updateUI() {
    const activeData = works[activeIndex];
    
    // 1. マップ上のアクティブ状態とレティクル移動
    const points = document.querySelectorAll("[data-work]");
    const reticle = document.getElementById("map-reticle");
    
    points.forEach((p, i) => {
      const isSelected = i === activeIndex;
      p.classList.toggle("is-active", isSelected);
      if (isSelected) {
        reticle.style.opacity = "1";
        reticle.style.left = p.style.left;
        reticle.style.bottom = p.style.bottom;
      }
    });

    // 2. HUDパネルの更新
    document.getElementById("hud-title").innerText = activeData.title;
    document.getElementById("hud-id").innerText = `ID: ${activeData.artist}`;
    const ytId = getYoutubeId(activeData.url);
    document.getElementById("hud-thumb").innerHTML = ytId 
      ? `<img src="https://img.youtube.com/vi/${ytId}/mqdefault.jpg" class="w-full h-full object-cover shadow-inner" />`
      : `<div class="w-full h-full bg-zinc-800"></div>`;

    // 3. ホイールの回転
    const track = document.getElementById("wheel-track");
    const angleStep = 12; // 1項目あたりの回転角度
    track.style.transform = `translateX(-50%) rotate(${activeIndex * -angleStep}deg)`;
    
    document.querySelectorAll(".wheel-item").forEach((item, i) => {
      item.classList.toggle("is-active", i === activeIndex);
    });
  }

  // キーボード & マウスホイール操作
  window.addEventListener("wheel", (e) => {
    if (Math.abs(e.deltaY) < 10) return;
    e.deltaY > 0 ? focusItem(activeIndex + 1) : focusItem(activeIndex - 1);
  }, { passive: true });

  window.addEventListener("keydown", (e) => {
    if (e.key === "ArrowRight" || e.key === "ArrowDown") focusItem(activeIndex + 1);
    if (e.key === "ArrowLeft" || e.key === "ArrowUp") focusItem(activeIndex - 1);
  });

  // 初期化
  window.focusItem = focusItem;
  window.setTag = (tag) => { currentTag = tag; /* フィルタロジックは必要に応じて拡張 */ };
  document.addEventListener("DOMContentLoaded", () => focusItem(0));
</script>

---
import { works } from '../data/works';
import '../styles/global.css';

const allTags = [...new Set(works.flatMap(w => w.tags ?? []))];
---

<style>
  /* 🔵 全体レイアウト：左にマップ、右にHUD操作系 */
  .console-wrapper {
    display: grid;
    grid-template-columns: 1fr 340px;
    height: 85vh;
    gap: 20px;
    background: #000;
    padding: 20px;
    font-family: 'JetBrains Mono', monospace;
    overflow: hidden;
  }

  /* 🟢 左側：戦術マップ */
  .tactical-map {
    position: relative;
    border: 1px solid rgba(34, 211, 238, 0.2);
    background: rgba(34, 211, 238, 0.02);
    overflow: hidden;
  }

  /* 🎯 マップ内のレティクル（十字線） */
  #map-reticle {
    position: absolute;
    width: 60px;
    height: 60px;
    border: 1px solid rgba(34, 211, 238, 0.6);
    pointer-events: none;
    z-index: 50;
    transform: translate(-50%, 50%);
    transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
  }
  #map-reticle::before, #map-reticle::after {
    content: ''; position: absolute; background: #22d3ee; box-shadow: 0 0 10px #22d3ee;
  }
  #map-reticle::before { width: 100%; height: 1px; top: 50%; left: 0; }
  #map-reticle::after { width: 1px; height: 100%; left: 50%; top: 0; }

  /* 🟢 右側：HUDユニット（ホイール & 情報） */
  .hud-unit {
    position: relative;
    border-left: 1px solid rgba(34, 211, 238, 0.3);
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .wheel-viewport {
    position: absolute;
    right: -800px; /* 巨大な円を右に沈める */
    top: 50%;
    transform: translateY(-50%);
    width: 1600px;
    height: 1600px;
  }

  .circular-track {
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid rgba(34, 211, 238, 0.1);
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .wheel-item {
    position: absolute;
    left: 20px;
    top: 50%;
    width: 280px;
    transform-origin: 800px center;
    transition: all 0.4s;
    opacity: 0.2;
    color: #22d3ee;
  }

  .wheel-item.is-active {
    opacity: 1;
    transform: rotate(0deg) translateX(-30px);
    filter: drop-shadow(0 0 12px rgba(34, 211, 238, 0.9));
  }

  /* 情報表示エリア */
  .info-panel {
    z-index: 10;
    background: rgba(0,0,0,0.8);
    border-left: 2px solid #22d3ee;
    padding: 15px;
    margin-bottom: 20px;
  }

  [data-work] {
    position: absolute;
    transition: opacity 0.6s, transform 0.6s;
    transform: translate(-50%, 50%);
  }
  [data-work].is-active {
    filter: drop-shadow(0 0 8px #22d3ee);
    z-index: 100;
  }
</style>

<div class="console-wrapper border border-cyan-900/50">
  
  <div class="tactical-map">
    <div id="map-reticle" class="opacity-0"></div>
    <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(#22d3ee 1px, transparent 1px), linear-gradient(90deg, #22d3ee 1px, transparent 1px); background-size: 50px 50px;"></div>
    
    <div class="absolute inset-16">
      {works.map((work, index) => {
        const x = ((work.x + 100) / 200) * 100;
        const y = ((work.y + 100) / 200) * 100;
        return (
          <div 
            data-work 
            data-index={index}
            style={`left: ${x}%; bottom: ${y}%;`}
            onclick={`focusItem(${index})`}
          >
            <div class="w-2 h-2 border border-cyan-500/50 bg-cyan-500/20"></div>
          </div>
        );
      })}
    </div>
  </div>

  <div class="hud-unit">
    <div class="info-panel space-y-4">
      <div id="hud-thumb" class="w-full aspect-video bg-zinc-900 border border-cyan-900 overflow-hidden"></div>
      <div>
        <p id="hud-id" class="text-[8px] text-cyan-500/50">ID: ----</p>
        <h2 id="hud-title" class="text-sm font-bold text-white uppercase tracking-tighter">Initializing...</h2>
      </div>
      <div id="hud-tags" class="flex flex-wrap gap-1"></div>
      <a id="hud-link" href="#" target="_blank" class="block text-center border border-cyan-500 py-2 text-[10px] hover:bg-cyan-500 hover:text-black transition-all">ACCESS DATA</a>
    </div>

    <div class="wheel-viewport pointer-events-none">
      <div id="circular-track" class="circular-track">
        {works.map((work, i) => (
          <div class="wheel-item text-[9px] font-black uppercase whitespace-nowrap" data-wheel-index={i}>
            {work.title}
          </div>
        ))}
      </div>
    </div>
    
    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-10 h-[1px] bg-cyan-400 shadow-[0_0_10px_#22d3ee]"></div>
  </div>
</div>

<script define:vars={{ works }}>
  let activeIndex = 0;

  function focusItem(index) {
    activeIndex = Math.max(0, Math.min(index, works.length - 1));
    updateHUD();
  }

  function updateHUD() {
    const data = works[activeIndex];
    
    // 1. マップとレティクルの同期
    document.querySelectorAll("[data-work]").forEach((p, i) => {
      p.classList.toggle("is-active", i === activeIndex);
    });
    const target = document.querySelector(`[data-work][data-index="${activeIndex}"]`);
    const reticle = document.getElementById("map-reticle");
    if (target) {
      reticle.style.opacity = "1";
      reticle.style.left = target.style.left;
      reticle.style.bottom = target.style.bottom;
    }

    // 2. ホイール回転
    const angleStep = 10;
    const track = document.getElementById("circular-track");
    track.style.transform = `rotate(${activeIndex * -angleStep}deg)`;
    
    document.querySelectorAll(".wheel-item").forEach((item, i) => {
      item.classList.toggle("is-active", i === activeIndex);
      const angle = i * angleStep;
      item.style.transform = `rotate(${angle}deg) translateX(0px)`;
    });

    // 3. 情報表示更新
    document.getElementById("hud-title").innerText = data.title;
    document.getElementById("hud-id").innerText = `ID: ${data.artist}`;
    document.getElementById("hud-link").href = data.url;
    const ytId = data.url?.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=)([^#\&\?]*)/)?.[1];
    document.getElementById("hud-thumb").innerHTML = ytId 
      ? `<img src="https://img.youtube.com/vi/${ytId}/mqdefault.jpg" class="w-full h-full object-cover" />`
      : "";
  }

  // 入力制御
  window.addEventListener("wheel", (e) => {
    e.deltaY > 0 ? focusItem(activeIndex + 1) : focusItem(activeIndex - 1);
  }, { passive: true });

  window.addEventListener("keydown", (e) => {
    if (["ArrowUp", "ArrowLeft"].includes(e.key)) focusItem(activeIndex - 1);
    if (["ArrowDown", "ArrowRight"].includes(e.key)) focusItem(activeIndex + 1);
  });

  window.focusItem = focusItem;
  document.addEventListener("DOMContentLoaded", () => focusItem(0));
</script>

---
import { works } from '../data/works';
import '../styles/global.css';

const allTags = [...new Set(works.flatMap(w => w.tags ?? []))];
---

<style>
  /* --------------------------------------------------
   * 🌫️ 【仕様固定】画面全体の初期状態
   * -------------------------------------------------- */
  :global(body.is-blurred) {
    filter: blur(20px) saturate(0.5);
    pointer-events: none;
    overflow: hidden;
  }

  :global(body) {
    /* 🌈 ドップラー効果：filterをJSから制御するため transition を設定 */
    transition: filter 1.2s cubic-bezier(0.4, 0, 0.2, 1), background-color 2s ease;
    background-color: #09090b;
    margin: 0;
    color: white;
    min-height: 100vh;
  }

  /* 🎬 始動用オーバーレイ */
  #start-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.8);
    cursor: pointer;
    pointer-events: auto !important;
    transition: opacity 0.8s ease, visibility 0.8s;
  }

  #start-overlay.hidden { opacity: 0; visibility: hidden; }

  /* 📧 Contact Bar */
  .contact-bar {
    display: flex;
    justify-content: flex-end;
    padding: 10px 20px;
    font-size: 10px;
    letter-spacing: 0.2em;
    border-bottom: 1px solid rgba(34, 211, 238, 0.1);
    position: relative;
    z-index: 10;
  }

  .contact-link { color: #71717a; cursor: pointer; transition: all 0.3s ease; position: relative; display: flex; align-items: center; gap: 8px; }
  .contact-link:hover { color: #22d3ee; }
  .copy-feedback { position: absolute; right: 0; top: 120%; background: #22d3ee; color: #000; padding: 2px 6px; font-weight: bold; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; white-space: nowrap; }
  .copy-feedback.is-visible { opacity: 1; }

  /* 🔵 レイアウト構成 */
  .main-layout {
    display: grid;
    grid-template-columns: 1fr 240px; 
    gap: 20px;
    max-width: 1200px;
    margin: 20px auto;
    font-family: 'JetBrains Mono', monospace;
    opacity: 0;
    transition: opacity 1s ease 0.5s;
  }

  :global(body:not(.is-blurred)) .main-layout { opacity: 1; }

  /* グラフ・ポイント演出 */
  .map-container { perspective: 1200px; transform-style: preserve-3d; position: relative; isolation: isolate; }
  @keyframes float {
    0%, 100% { transform: translate(-50%, 50%) rotate(0deg); }
    33% { transform: translate(calc(-50% + 4px), calc(50% - 6px)) rotate(1deg); }
    66% { transform: translate(calc(-50% - 3px), calc(50% - 2px)) rotate(-1deg); }
  }
  [data-work] { position: absolute; transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1); transform: translate(-50%, 50%); }
  [data-work].is-active { opacity: 1; z-index: 100; transform: translate(-50%, 50%) translateZ(120px) scale(1.2); filter: drop-shadow(0 0 10px rgba(34, 211, 238, 0.8)); }
  [data-work].is-inactive { opacity: 0.1; z-index: 0; transform: translate(-50%, 50%) translateZ(-300px) scale(0.7); pointer-events: none; }
  .animate-float { animation: float 6s ease-in-out infinite; }

  /* 🎚️ オーディオHUD */
  .audio-hud { display: flex; flex-direction: column; gap: 24px; padding: 20px; background: rgba(9, 9, 11, 0.5); border: 1px solid rgba(34, 211, 238, 0.1); height: fit-content; position: relative; z-index: 20; }
  .control-group { display: flex; flex-direction: column; gap: 8px; }
  .control-label { font-size: 9px; color: #22d3ee; text-transform: uppercase; letter-spacing: 0.1em; }
  input[type="range"] { appearance: none; background: #27272a; height: 2px; outline: none; width: 100%; }
  input[type="range"]::-webkit-slider-thumb { appearance: none; width: 10px; height: 10px; background: #22d3ee; border-radius: 50%; cursor: pointer; }
</style>

<div id="start-overlay">
  <span class="text-cyan-400 text-[10px] tracking-[0.4em] animate-pulse uppercase border border-cyan-400/50 px-4 py-2 bg-black/60">Initialize System</span>
  <p class="text-zinc-600 text-[8px] uppercase tracking-widest mt-2">Click Anywhere to Begin</p>
</div>

<div class="contact-bar">
  <div class="contact-link" onclick="copyContact('info@corecreative.jp')">
    <span class="text-zinc-500">CONTACT:</span>
    <span id="contact-text">info@corecreative.jp</span>
    <div id="copy-toast" class="copy-feedback">COPIED TO CLIPBOARD</div>
  </div>
</div>

<div class="max-w-4xl mx-auto mb-4 flex flex-wrap gap-2 text-xs pt-4 px-4">
  <button id="btn-all" onclick="setTag(null)" class="px-2 py-1 border border-zinc-700 hover:text-cyan-400 transition-all">ALL</button>
  {allTags.map(tag => (
    <button id={`btn-${tag}`} onclick={`setTag("${tag}")`} class="px-2 py-1 border border-zinc-800 hover:text-cyan-400 transition-all">{tag}</button>
  ))}
</div>

<div class="main-layout">
  <div class="relative aspect-square px-4">
    <div id="map-target" class="map-container w-full h-full bg-zinc-950 border border-zinc-800 overflow-hidden font-mono text-[10px]">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #27272a 1px, transparent 1px); background-size: 20px 20px;"></div>
      <div class="absolute inset-16 sm:inset-24">
        {works.map((work, index) => {
          const left = ((work.x + 100) / 200) * 100;
          const bottom = ((work.y + 100) / 200) * 100;
          const ytId = work.url?.match(/(?:youtu\.be\/|youtube\.com\/watch\?v=)([^#\&\?]*)/)?.[1];
          return (
            <div data-work data-tags={work.tags?.join(",") ?? ""} class="group absolute cursor-crosshair animate-float" style={`left: ${left}%; bottom: ${bottom}%; animation-delay: ${index * 0.2}s; z-index: ${Math.round(bottom)};`}>
              <a href={work.url} target="_blank" class="relative w-4 h-4 flex items-center justify-center">
                <div class="absolute w-full h-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
                <div class="absolute h-full w-[1px] bg-zinc-600 group-hover:bg-cyan-400"></div>
                <div class="w-1 h-1 bg-white"></div>
              </a>
              <div class={`absolute mb-2 w-[220px] z-[100] opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-300 ease-out delay-1200 group-hover:delay-[400ms] ${bottom > 70 ? 'top-6' : 'bottom-full'} ${left > 70 ? 'right-4' : 'left-4'}`}>
                <div class="bg-black/95 border-l-2 border-cyan-500 backdrop-blur-xl shadow-2xl overflow-hidden">
                  {ytId && <img src={`https://img.youtube.com/vi/${ytId}/mqdefault.jpg`} class="w-full aspect-video object-cover" />}
                  <div class="p-3">
                    <p class="text-[8px] text-cyan-500/70 mb-1 uppercase">ID: {work.artist}</p>
                    <p class="text-white font-bold leading-tight mb-2 line-clamp-2">{work.title}</p>
                    <div class="flex items-center justify-between text-[9px] text-zinc-400 border border-zinc-800 px-2 py-1.5 uppercase bg-zinc-900/50">
                      <span>Access Data</span><span>→</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <aside class="audio-hud">
    <div class="control-group"><label class="control-label">Master Volume</label><input type="range" id="vol-fader" min="0" max="1" step="0.01" value="0.5"></div>
    <div class="control-group"><label class="control-label">Playback Speed</label><input type="range" id="speed-fader" min="0.5" max="2" step="0.01" value="1.0"></div>
    <div class="control-group"><label class="control-label">Pitch Shift</label><input type="range" id="pitch-fader" min="0.5" max="2" step="0.01" value="1.0"></div>
    <div class="mt-4 pt-4 border-t border-zinc-800">
      <div id="v-meter" class="h-1 w-full bg-zinc-900 overflow-hidden"><div id="v-bar" class="h-full bg-cyan-400 w-0 transition-all duration-100"></div></div>
      <p class="text-[7px] text-zinc-600 mt-1 uppercase">Audio Signal Analysis</p>
      <p id="doppler-status" class="text-[6px] text-cyan-900 mt-2 uppercase tracking-tighter">Shift: Stable</p>
    </div>
  </aside>
</div>

<script>
  let currentTag = null;
  let audioContext = null;
  let source = null;
  let gainNode = null;
  let isStarted = false;
  
  // 🌈 ドップラー効果用の変数
  let baseHue = 0;
  let currentSpeed = 1.0;

  (window as any).copyContact = (text) => {
    navigator.clipboard.writeText(text).then(() => {
      const toast = document.getElementById('copy-toast');
      toast.classList.add('is-visible');
      setTimeout(() => toast.classList.remove('is-visible'), 2000);
    });
  };

  function initBodyBlur() { document.body.classList.add('is-blurred'); }

  // 🌈 ドップラー効果と時間経過による色遷移の更新ループ
  function updateVisualShift() {
    if (!isStarted) return;

    // 1. 時間経過でベースの色相をゆっくり回す (0.1度ずつ)
    baseHue = (baseHue + 0.1) % 360;

    // 2. 再生速度に応じた「ズレ」を計算
    // 速度1.0を基準に、速いほど青っぽく(Blue Shift)、遅いほど赤っぽく(Red Shift)
    const speedDelta = currentSpeed - 1.0;
    const shiftHue = baseHue + (speedDelta * 60); // 速度差で最大60度程度色相をズラす
    
    // 3. 速度に応じた彩度とコントラストの歪み
    const saturation = 0.5 + (currentSpeed * 0.5); // 速いほど鮮やかに
    const brightness = 0.8 + (Math.abs(speedDelta) * 0.4); // 速度変化があるほど発光
    
    // 4. 画面全体に適用 (bodyのfilterを更新)
    document.body.style.filter = `hue-rotate(${shiftHue}deg) saturate(${saturation}) brightness(${brightness})`;
    
    // ステータス表示の更新
    const status = document.getElementById('doppler-status');
    if (status) {
      if (currentSpeed > 1.1) status.innerText = `Shift: Blue (Approach)`;
      else if (currentSpeed < 0.9) status.innerText = `Shift: Red (Recede)`;
      else status.innerText = `Shift: Stable`;
    }

    requestAnimationFrame(updateVisualShift);
  }

  async function startExperience() {
    if (isStarted) return;
    isStarted = true;
    document.getElementById('start-overlay').classList.add('hidden');
    document.body.classList.remove('is-blurred');
    document.body.style.overflow = 'auto';

    // ビジュアルループ開始
    updateVisualShift();

    try {
      audioContext = new (window.AudioContext || (window as any).webkitAudioContext)();
      const response = await fetch('/SITE_th.mp3');
      const arrayBuffer = await response.arrayBuffer();
      const audioBuffer = await audioContext.decodeAudioData(arrayBuffer);
      source = audioContext.createBufferSource();
      source.buffer = audioBuffer;
      source.loop = true;
      gainNode = audioContext.createGain();
      gainNode.gain.value = 0.5;
      source.connect(gainNode);
      gainNode.connect(audioContext.destination);
      source.start(0);

      const volFader = document.getElementById('vol-fader') as HTMLInputElement;
      const speedFader = document.getElementById('speed-fader') as HTMLInputElement;
      const pitchFader = document.getElementById('pitch-fader') as HTMLInputElement;

      volFader.addEventListener('input', (e: any) => gainNode.gain.value = parseFloat(e.target.value));
      
      const updateRate = (val: string) => {
        currentSpeed = parseFloat(val); // 🌈 グローバルな速度変数を更新
        source.playbackRate.value = currentSpeed;
        speedFader.value = val;
        pitchFader.value = val;
      };

      speedFader.addEventListener('input', (e: any) => updateRate(e.target.value));
      pitchFader.addEventListener('input', (e: any) => updateRate(e.target.value));

      const vBar = document.getElementById('v-bar');
      setInterval(() => {
        const level = Math.random() * (gainNode.gain.value * 100);
        if(vBar) vBar.style.width = `${level}%`;
      }, 100);
    } catch (e) { console.error(e); }
  }

  function applyFilters() {
    const allWorks = document.querySelectorAll("[data-work]");
    const allBtns = document.querySelectorAll("button[id^='btn-']");
    allBtns.forEach(btn => btn.classList.remove('border-cyan-500', 'text-cyan-400'));
    const activeBtn = currentTag ? document.getElementById(`btn-${currentTag}`) : document.getElementById('btn-all');
    activeBtn?.classList.add('border-cyan-500', 'text-cyan-400');

    allWorks.forEach((el: any) => {
      const tags = (el.dataset.tags || "").split(",").map((t: string) => t.trim()).filter(Boolean);
      if (!currentTag) {
        el.classList.remove('is-active', 'is-inactive');
      } else if (tags.includes(currentTag)) {
        el.classList.add('is-active'); el.classList.remove('is-inactive');
      } else {
        el.classList.add('is-inactive'); el.classList.remove('is-active');
      }
    });
  }

  (window as any).setTag = (tag: string) => {
    if (!isStarted) startExperience();
    currentTag = tag;
    applyFilters();
  };

  document.addEventListener('DOMContentLoaded', () => {
    initBodyBlur();
    applyFilters();
    document.getElementById('start-overlay')?.addEventListener('click', startExperience);
  });
</script>

---
import { works } from '../data/works';
import '../styles/global.css';

// 🔥 タグ一覧自動生成
const allTags = [...new Set(works.flatMap(w => w.tags ?? []))];
---

<style>
  /* 浮遊アニメーション */
  @keyframes float {
    0%, 100% { transform: translate(-50%, 50%); }
    50% { transform: translate(-50%, calc(50% - 5px)); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
</style>

<div class="max-w-4xl mx-auto mb-4 flex flex-wrap gap-2 text-xs">
  <button onclick="setTag(null)" class="hover:text-cyan-400 transition-colors">ALL</button>

  {allTags.map(tag => (
    <button onclick={`setTag("${tag}")`} class="hover:text-cyan-400 transition-colors">
      {tag}
    </button>
  ))}
</div>

<div class="relative w-full max-w-4xl mx-auto aspect-square bg-zinc-950 border border-zinc-800 overflow-hidden font-mono text-[10px] sm:text-xs selection:bg-cyan-500/30">
  
  <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle, #27272a 1px, transparent 1px); background-size: 20px 20px;"></div>
  <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
    <div class="w-full h-[1px] bg-zinc-800"></div>
    <div class="absolute h-full w-[1px] bg-zinc-800"></div>
  </div>

  <div class="absolute top-6 left-1/2 -translate-x-1/2 text-zinc-600 tracking-[0.2em] uppercase font-black">Maniac [+]</div>
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-zinc-600 tracking-[0.2em] uppercase font-black">Popular [-]</div>
  <div class="absolute left-6 top-1/2 -translate-y-1/2 -rotate-90 text-zinc-600 tracking-[0.2em] uppercase font-black origin-left">Electro [L]</div>
  <div class="absolute right-6 top-1/2 -translate-y-1/2 rotate-90 text-zinc-600 tracking-[0.2em] uppercase font-black origin-right">Acoustic [R]</div>

  <div class="absolute inset-16 sm:inset-24">
    {works.map((work, index) => {
      const left = ((work.x + 100) / 200) * 100;
      const bottom = ((work.y + 100) / 200) * 100;

      return (
        <div 
          data-work
          data-tags={work.tags?.join(",") ?? ""}
          class="group absolute cursor-crosshair animate-float"
          style={`left: ${left}%; bottom: ${bottom}%; animation-delay: ${index * 0.2}s;`}
        >
          <div class="relative w-4 h-4 flex items-center justify-center">
            <div class="absolute w-full h-[1px] bg-zinc-600 group-hover:bg-cyan-400 transition-colors"></div>
            <div class="absolute h-full w-[1px] bg-zinc-600 group-hover:bg-cyan-400 transition-colors"></div>
            <div class="w-1 h-1 bg-white group-hover:scale-150 transition-transform"></div>
          </div>
          
          <div class="absolute bottom-full left-4 mb-2 w-max max-w-[180px] z-10
                      opacity-0 translate-y-2 pointer-events-none
                      group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto
                      transition-all duration-300 ease-out
                      delay-500 group-hover:delay-[400ms]">
            <div class="bg-black/90 border-l-2 border-cyan-500 p-3 backdrop-blur-md shadow-xl">
              <p class="text-[8px] text-cyan-500/70 mb-1 tracking-tighter">
                ID: {(work.artist ?? "").toUpperCase()}
              </p>

              <p class="text-white font-bold leading-tight mb-2 tracking-tight">
                {work.title}
              </p>

              {work.tags && (
                <div class="flex gap-1 mt-1 flex-wrap">
                  {work.tags.map(tag => (
                    <span class="text-[8px] bg-zinc-800 px-1">{tag}</span>
                  ))}
                </div>
              )}

              <a 
                href={work.url} 
                target="_blank"
                class="inline-block text-[9px] text-zinc-400 hover:text-white border border-zinc-700 px-2 py-1 transition-colors uppercase tracking-widest mt-2"
              >
                Access Data _
              </a>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</div>

<script>
  let filters = { tag: null };

  function applyFilters() {
    document.querySelectorAll("[data-work]").forEach((el) => {
      const tags = (el.dataset.tags || "").split(",").map(t => t.trim()).filter(Boolean);
      let visible = !filters.tag || tags.includes(filters.tag);
      (el as HTMLElement).style.display = visible ? "block" : "none";
    });
  }

  window.setTag = (tag) => {
    filters.tag = tag;
    applyFilters();
  };
</script>
